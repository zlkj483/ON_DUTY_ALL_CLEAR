--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9c91c1e9404041849bcfdecd98a4c9b2, type: 3}
  m_Name: Mission Text Table SO
  m_EditorClassIdentifier: 
  missionTextSets:
  - missionIndex: 1
    texts:
    - role: 0
      text: "\uAD50\uB3C4\uC18C\uC5D0\uC11C \uC2DC\uB044\uB7FD\uAC8C \uAD6C\uB294
        \uC8C4\uC218\uB4E4\uC744 \uC804\uBD80 \uC9C4\uC555\uD558\uB77C!"
      info: "\uC624\uB298\uC758 \uBBF8\uC158 UI \uD0C0\uC774\uD2C0 01 | \uBBF8\uC158
        \uC131\uACF5 UI \uD0C0\uC774\uD2C0 01"
    - role: 1
      text: "\uBA4D\uCCAD\uD55C \uC8C4\uC218\uB4E4\uC774 \uAD50\uB3C4\uC18C\uB97C
        \uC2DC\uB044\uB7FD\uAC8C \uB9CC\uB4E4\uACE0 \uC788\uB2E4.\n\uC8C4\uC218\uB4E4\uC744
        \uC2DC\uB044\uB7EC\uC6B4 \uC0C1\uD0DC\uB85C \uBC29\uCE58\uD558\uBA74\n\uC774
        \uD2C8\uC744 \uD0C0 \uC218\uC0C1\uD55C \uC9D3\uC744 \uD558\uB294 \uB188\uB4E4\uC774
        \uC0DD\uAE34\uB2E4.\n\uC2DC\uB044\uB7EC\uC6B4 \uC8C4\uC218\uB4E4\uC744 \uC804\uBD80
        \uC9C4\uC555\uD558\uC790."
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uC0C1\uC138 \uB0B4\uC6A9 01"
    - role: 2
      text: "\uC2DC\uB044\uB7EC\uC6B4 \uC8C4\uC218 6\uBA85 \uC9C4\uC555\uD558\uAE30"
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uC644\uB8CC \uC870\uAC74 01"
    - role: 3
      text: "\uC2DC\uB044\uB7EC\uC6B4 \uC8C4\uC218"
      info: "\uBBF8\uC158 \uC9C4\uD589\uB3C4 \uD14D\uC2A4\uD2B8 01"
    - role: 4
      text: "\uC2DC\uB044\uB7EC\uC6B4 \uC8C4\uC218\uB4E4\uC744 \uC870\uC6A9\uD788
        \uC2DC\uD0A4\uC9C0 \uBABB\uD568"
      info: "\uD574\uACE0 \uC0AC\uC720 \uC0C1\uC138 \uB0B4\uC6A9 01"
  - missionIndex: 2
    texts:
    - role: 0
      text: "\uC8C4\uC218\uB4E4\uC774 \uAC10\uBC29\uC5D0 \uC228\uACA8 \uB193\uC740
        \uBB34\uAE30\uB97C \uC804\uBD80 \uC555\uC218\uD558\uB77C!"
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uD0C0\uC774\uD2C0 02 | \uBBF8\uC158
        \uC131\uACF5 UI \uD0C0\uC774\uD2C0 02"
    - role: 1
      text: "\uC8C4\uC218\uB4E4\uC774 \uAC10\uBC29 \uC548\uC5D0 \uBB34\uAE30\uB97C
        \uC228\uACA8 \uB1A8\uB2E4\uB294 \uC2E0\uACE0\uAC00 \uB4E4\uC5B4\uC654\uB2E4.\n\uBB34\uAE30\uB97C
        \uC555\uC218\uD558\uC9C0 \uC54A\uC73C\uBA74 \uC0AC\uACE0\uAC00 \uC77C\uC5B4\uB0A0
        \uAC83\uC774 \uBD84\uBA85\uD558\uB2E4.\n\uC8C4\uC218\uB4E4\uC774 \uC228\uACA8\uB193\uC740
        \uBB34\uAE30\uB97C \uC804\uBD80 \uC555\uC218\uD558\uC790."
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uC0C1\uC138 \uB0B4\uC6A9 02"
    - role: 2
      text: "\uC8C4\uC218\uB4E4\uC774 \uAC10\uBC29\uC5D0 \uC228\uACA8\uB193\uC740
        \uBB34\uAE30 7\uAC1C \uC555\uC218\uD558\uAE30"
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uC644\uB8CC \uC870\uAC74 02"
    - role: 3
      text: "\uC555\uC218\uD55C \uBB34\uAE30"
      info: "\uBBF8\uC158 \uC9C4\uD589\uB3C4 \uD14D\uC2A4\uD2B8 02"
    - role: 4
      text: "\uC8C4\uC218\uB4E4\uC774 \uC228\uACA8\uB454 \uBB34\uAE30\uB97C \uC804\uBD80
        \uC555\uC218\uD558\uC9C0 \uBABB\uD574 \uC0AC\uACE0\uAC00 \uBC1C\uC0DD\uD568"
      info: "\uD574\uACE0 \uC0AC\uC720 \uC0C1\uC138 \uB0B4\uC6A9 02"
  - missionIndex: 3
    texts:
    - role: 0
      text: "\uC774\uC0C1\uD55C \uD589\uB3D9\uC744 \uD558\uB294 \uC8C4\uC218\uB4E4\uC744
        \uC804\uBD80 \uC9C4\uC555\uD558\uB77C!"
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uD0C0\uC774\uD2C0 03 | \uBBF8\uC158
        \uC131\uACF5 UI \uD0C0\uC774\uD2C0 03"
    - role: 1
      text: "\uAD50\uB3C4\uC18C\uC5D0 \uC0C8\uB85C \uB4E4\uC5B4\uC628 \uC8C4\uC218\uB4E4\uC774
        \uC774\uC0C1\uD55C \uC9D3\uC744 \uD558\uACE0 \uC788\uB2E4.\n\uBAA8\uB4E0
        \uAC10\uBC29\uC744 \uD655\uC778\uD558\uACE0, \uC218\uC0C1\uD55C \uC9D3\uAC70\uB9AC\uB97C
        \uD558\uB294 \uB188\uB4E4\uC744 \uC804\uBD80 \uC9C4\uC555\uD558\uC790."
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uC0C1\uC138 \uB0B4\uC6A9 03"
    - role: 2
      text: "\uC774\uC0C1\uD55C \uD589\uB3D9\uC744 \uD558\uB294 \uC8C4\uC218 6\uBA85
        \uC804\uBD80 \uC9C4\uC555\uD558\uAE30"
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uC644\uB8CC \uC870\uAC74 03"
    - role: 3
      text: "\uC9C4\uC555\uD55C \uC774\uC0C1 \uD589\uB3D9 \uC8C4\uC218"
      info: "\uBBF8\uC158 \uC9C4\uD589\uB3C4 \uD14D\uC2A4\uD2B8 03"
    - role: 4
      text: "\uC774\uC0C1\uD55C \uC9D3\uC744 \uD558\uB294 \uC8C4\uC218\uB97C \uBC29\uCE58\uD55C
        \uD0D3\uC5D0 \uC774\uC81C\uB294 \uC8C4\uB2E4 \uC774\uC0C1\uD55C \uC9D3\uC744
        \uD558\uACE0 \uC788\uC74C"
      info: "\uD574\uACE0 \uC0AC\uC720 \uC0C1\uC138 \uB0B4\uC6A9 03"
  - missionIndex: 4
    texts:
    - role: 0
      text: "'\uD504\uB7AD\uD06C'\uB97C \uCC3E\uC544\uB77C!"
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uD0C0\uC774\uD2C0 04 | \uBBF8\uC158
        \uC131\uACF5 UI \uD0C0\uC774\uD2C0 04"
    - role: 1
      text: "\uAD50\uB3C4\uC18C\uB85C \uC21C\uCC30\uD558\uB7EC \uB0B4\uB824\uAC04
        \uC120\uC784 \uAD50\uB3C4\uAD00, \uD504\uB7AD\uD06C\uAC00 \uB3CC\uC544\uC624\uC9C0
        \uC54A\uACE0 \uC788\uB2E4.\n\uAD50\uB3C4\uC18C\uB85C \uB0B4\uB824\uAC00\uC11C
        \uD504\uB7AD\uD06C\uB97C \uCC3E\uC544\uBCF4\uC790."
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uC0C1\uC138 \uB0B4\uC6A9 04"
    - role: 2
      text: "\uC120\uC784 \uAD50\uB3C4\uAD00\uC778 \uD504\uB7AD\uD06C\uB97C \uCC3E\uACE0,
        \uAC00\uC9DC \uD504\uB7AD\uD06C\uB97C \uC9C4\uC555\uD558\uAE30"
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uC644\uB8CC \uC870\uAC74 04"
    - role: 3
      text: "\uAC00\uC9DC \uD504\uB7AD\uD06C \uC9C4\uC555"
      info: "\uBBF8\uC158 \uC9C4\uD589\uB3C4 \uD14D\uC2A4\uD2B8 04"
    - role: 4
      text: "\uC9C4\uC9DC \uC120\uC784 \uAD50\uB3C4\uAD00\uACFC \uBCC0\uC7A5\uD55C
        \uC8C4\uC218\uB97C \uAD6C\uBD84\uD558\uC9C0 \uBABB\uD568"
      info: "\uD574\uACE0 \uC0AC\uC720 \uC0C1\uC138 \uB0B4\uC6A9 04"
  - missionIndex: 5
    texts:
    - role: 0
      text: "\uAE08\uC9C0 \uBB3C\uD488\uC744 \uC555\uC218\uD558\uB77C!"
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uD0C0\uC774\uD2C0 05 | \uBBF8\uC158
        \uC131\uACF5 UI \uD0C0\uC774\uD2C0 05"
    - role: 1
      text: "\uC8C4\uC218\uB4E4\uC740 \uC5B4\uB5BB\uAC8C\uB4E0 \uAD50\uB3C4\uC18C
        \uC548\uC5D0 \uAE08\uC9C0 \uBB3C\uD488\uC744 \uBC18\uC785\uD574\uC628\uB2E4.\n\uBC18\uC785\uC744
        \uB9C9\uC744 \uC218\uB294 \uC5C6\uC9C0\uB9CC, \uBC29\uCE58\uD560 \uC218\uB3C4
        \uC5C6\uB2E4.\n\uC8C4\uC218\uB4E4\uC774 \uBC18\uC785\uD55C \uAE08\uC9C0 \uBB3C\uD488\uC744
        \uC804\uBD80 \uC555\uC218\uD558\uC790!"
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uC0C1\uC138 \uB0B4\uC6A9 05"
    - role: 2
      text: "\uAE08\uC9C0 \uBB3C\uD488 7\uC885 \uC555\uC218\uD558\uAE30"
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uC644\uB8CC \uC870\uAC74 05"
    - role: 3
      text: "\uC555\uC218\uD55C \uAE08\uC9C0 \uBB3C\uD488"
      info: "\uBBF8\uC158 \uC9C4\uD589\uB3C4 \uD14D\uC2A4\uD2B8 05"
    - role: 4
      text: "\uC8C4\uC218\uB4E4\uC774 \uBC18\uC785\uD55C \uAE08\uC9C0 \uBB3C\uD488\uC744
        \uBC29\uCE58\uD574 \uAD50\uB3C4\uC18C \uBD84\uC704\uAE30\uB97C \uC800\uD574\uD568"
      info: "\uD574\uACE0 \uC0AC\uC720 \uC0C1\uC138 \uB0B4\uC6A9 05"
  - missionIndex: 6
    texts:
    - role: 0
      text: "\uCD1D\uAE30\uB97C \uBC00\uBC18\uC785\uD55C \uBC94\uC778\uC744 \uCC3E\uC544\uB77C!"
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uD0C0\uC774\uD2C0 06 | \uBBF8\uC158
        \uC131\uACF5 UI \uD0C0\uC774\uD2C0 06"
    - role: 1
      text: "\uAC31\uB2E8\uC6D0 \uC911 \uD55C \uBA85\uC774 \uCD1D\uAE30\uB97C \uBC00\uBC18\uC785\uD588\uB2E4.\n\uC99D\uAC70
        \uBB3C\uD488\uC744 \uC798 \uAD00\uCC30\uD558\uACE0, 3\uBA85\uC758 \uC6A9\uC758\uC790\uC640
        \uB300\uD654\uB97C \uD55C \uB2E4\uC74C\n\uB204\uAC00 \uCD1D\uAE30\uB97C \uBC00\uBC18\uC785\uD55C
        \uBC94\uC778\uC778\uC9C0 \uCC3E\uC544\uB0B4 \uD504\uB7AD\uD06C\uC5D0\uAC8C
        \uC54C\uB824\uC8FC\uC790"
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uC0C1\uC138 \uB0B4\uC6A9 06"
    - role: 2
      text: "\uCD1D\uAE30\uB97C \uBC00\uBC18\uC785\uD55C \uAC31\uB2E8\uC6D0\uC744
        \uD2B9\uC815\uD55C \uB2E4\uC74C\n\uD504\uB7AD\uD06C\uC5D0\uAC8C \uBC94\uC778\uC774
        \uB204\uAD6C\uC778\uC9C0 \uC54C\uB824\uC8FC\uAE30"
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uC644\uB8CC \uC870\uAC74 06"
    - role: 3
      text: "\uBC94\uC778 \uC9C0\uBAA9"
      info: "\uBBF8\uC158 \uC9C4\uD589\uB3C4 \uD14D\uC2A4\uD2B8 06"
    - role: 4
      text: "\uC798\uBABB\uB41C \uBC94\uC778\uC744 \uACE8\uB77C \uAD50\uB3C4\uC18C
        \uC548\uC5D0 \uCD1D\uAE30\uAC00 \uC5EC\uB7FF \uB298\uC5B4\uB0A8"
      info: "\uD574\uACE0 \uC0AC\uC720 \uC0C1\uC138 \uB0B4\uC6A9 06"
  - missionIndex: 7
    texts:
    - role: 0
      text: "\uC608\uACE0\uB41C \uB2E8\uCCB4 \uD3ED\uB3D9\uC744 \uC9C4\uC555\uD558\uB77C!"
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uD0C0\uC774\uD2C0 07 | \uBBF8\uC158
        \uC131\uACF5 UI \uD0C0\uC774\uD2C0 07"
    - role: 1
      text: "\uC8C4\uC218\uB4E4\uC774 \uB2E8\uCCB4 \uD3ED\uB3D9\uC744 \uACC4\uD68D\uD558\uACE0
        \uC788\uB2E4\uB294 \uCCA9\uBCF4\uAC00 \uB4E4\uC5B4\uC654\uB2E4.\n\uC8C4\uC218\uB4E4\uC774
        \uD3ED\uB3D9\uC744 \uC77C\uC73C\uD0A4\uAE30 \uC804\uC5D0 \uC0AC\uC804\uC5D0
        \uC9C4\uC555\uD558\uC790.\n\uBAA8\uB4E0 \uC8C4\uC218\uB97C \uC804\uBD80 \uB450\uB4E4\uACA8
        \uD328\uC790."
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uC0C1\uC138 \uB0B4\uC6A9 07"
    - role: 2
      text: "\uBAA8\uB4E0 \uC8C4\uC218\uB97C \uC9C4\uC555\uD558\uAE30"
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uC644\uB8CC \uC870\uAC74 07"
    - role: 3
      text: "\uC8C4\uC218 \uC9C4\uC555"
      info: "\uBBF8\uC158 \uC9C4\uD589\uB3C4 \uD14D\uC2A4\uD2B8 07"
    - role: 4
      text: "\uC774\uBBF8 \uC608\uACE0\uB41C \uB2E8\uCCB4 \uD3ED\uB3D9\uC870\uCC28
        \uC9C4\uC555\uD558\uC9C0 \uBABB\uD574 \uAD50\uB3C4\uC18C\uC5D0 \uD63C\uB780\uC744
        \uBE5A\uC74C"
      info: "\uD574\uACE0 \uC0AC\uC720 \uC0C1\uC138 \uB0B4\uC6A9 07"
