  entries:
  - id: Ptxt_KR_Object_01
    text: Press [E]<br>to talk to the Senior Guard
    info: "\uC120\uC784 \uAD50\uB3C4\uAD00 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_02
    text: Press [E]<br>to talk to the Warden
    info: "\uAD50\uB3C4\uC18C\uC7A5 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_03
    text: Press [E]<br>to talk to the Prisoner
    info: "\uC8C4\uC218 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8(\uBBF8\uC158
      06)"
  - id: Ptxt_KR_Object_04
    text: Press [E]<br>to open the prison entrance
    info: "\uAD50\uB3C4\uC18C \uC785\uAD6C \uBB38 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_05
    text: Press [E]<br>to open the cabinet
    info: "\uCE90\uBE44\uB2DB \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_06
    text: Press [E]<br>to close the cabinet
    info: "\uCE90\uBE44\uB2DB \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_07
    text: Press [E]<br>to open the stairwell door
    info: "\uACC4\uB2E8 \uBB38 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_08
    text: Press [E]<br>to open the cell door
    info: "\uAC10\uBC29 \uBB38 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8 01"
  - id: Ptxt_KR_Object_09
    text: Press [E]<br>to close the cell door
    info: "\uAC10\uBC29 \uBB38 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8 02"
  - id: Ptxt_KR_Object_10
    text: Press [E]<br>to lift the toilet cover
    info: "\uBCC0\uAE30 \uCEE4\uBC84 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_11
    text: Press [E]<br>to peel off the poster
    info: "\uD3EC\uC2A4\uD130 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
