  m_Script: {fileID: 11500000, guid: 61d01197186f2f44b932089beb3014be, type: 3}
  m_Name: EN UI Text Table SO
  m_EditorClassIdentifier: 
  entries:
  - id: Utxt_KR_01
    text: 'On Duty: All Clear'
    info: "\uAC8C\uC784 \uD0C0\uC774\uD2C0"
  - id: Utxt_KR_02
    text: Start Shift
    info: "\uAC8C\uC784 \uC2DC\uC791 \uBC84\uD2BC"
  - id: Utxt_KR_03
    text: Settings
    info: "\uD658\uACBD \uC124\uC815 \uBC84\uD2BC(\uC778\uD2B8\uB85C\uC52C) | \uD658\uACBD
      \uC124\uC815 \uBC84\uD2BC(\uC77C\uC2DC\uC815\uC9C0 \uD328\uB110)"
  - id: Utxt_KR_04
    text: Credits
    info: "\uD06C\uB808\uB514\uD2B8 \uBC84\uD2BC"
  - id: Utxt_KR_05
    text: End Shift
    info: "\uAC8C\uC784 \uC885\uB8CC \uBC84\uD2BC"
  - id: Utxt_KR_06
    text: New Shift
    info: "\uC0C8\uB85C\uD558\uAE30 \uBC84\uD2BC"
  - id: Utxt_KR_07
    text: Continue Shift
    info: "\uC774\uC5B4\uD558\uAE30 \uBC84\uD2BC"
  - id: Utxt_KR_08
    text: To Title
    info: "\uD0C0\uC774\uD2C0 \uC774\uB3D9 \uBC84\uD2BC(\uC778\uD2B8\uB85C\uC52C)
      | \uD0C0\uC774\uD2C0 \uC774\uB3D9 \uBC84\uD2BC(\uBBF8\uC158 \uC131\uACF5 UI)
      | \uD0C0\uC774\uD2C0 \uC774\uB3D9 \uBC84\uD2BC(\uBBF8\uC158 \uC2E4\uD328 UI)
      | \uD0C0\uC774\uD2C0 \uC774\uB3D9 \uBC84\uD2BC(\uAC8C\uC784 \uC624\uBC84 UI)"
  - id: Utxt_KR_09
    text: Are you sure you want to quit?
    info: "\uAC8C\uC784 \uC885\uB8CC \uBB38\uAD6C"
  - id: Utxt_KR_10
    text: Yes
    info: "\uAC8C\uC784 \uC885\uB8CC \uD328\uB110 \uC608 \uBC84\uD2BC | \uBCF4\uACE0
      \uC804 \uD655\uC778 UI \uC608 \uBC84\uD2BC"
  - id: Utxt_KR_11
    text: No
    info: "\uAC8C\uC784 \uC885\uB8CC \uD328\uB110 \uD0C0\uC774\uD2C0 \uC774\uB3D9
      \uBC84\uD2BC | \uBCF4\uACE0 \uC804 \uD655\uC778 UI \uC544\uB2C8\uC624 \uBC84\uD2BC"
  - id: Utxt_KR_12
    text: Master
    info: "\uB9C8\uC2A4\uD130 \uBCFC\uB968 \uD14D\uC2A4\uD2B8"
  - id: Utxt_KR_13
    text: BGM
    info: "BGM \uBCFC\uB968 \uD14D\uC2A4\uD2B8"
  - id: Utxt_KR_14
    text: SFX
    info: "SFX \uBCFC\uB968 \uD14D\uC2A4\uD2B8"
  - id: Utxt_KR_15
    text: UI
    info: "UI \uBCFC\uB968 \uD14D\uC2A4\uD2B8"
  - id: Utxt_KR_16
    text: Korean
    info: "\uC5B8\uC5B4 \uC124\uC815 \uD55C\uAD6D\uC5B4"
  - id: Utxt_KR_17
    text: English
    info: "\uC5B8\uC5B4 \uC124\uC815 \uC601\uC5B4"
  - id: Utxt_KR_18
    text: Press [E] for Next
    info: "\uB2E4\uC774\uC5BC\uB85C\uADF8 \uBC84\uD2BC \uC548\uB0B4 E"
  - id: Utxt_KR_19
    text: Press [Q] to Close
    info: "\uB2E4\uC774\uC5BC\uB85C\uADF8 \uBC84\uD2BC \uC548\uB0B4 Q"
  - id: Utxt_KR_20
    text: Days Since Last Accident
    info: "\uBB34\uC0AC\uACE0 \uB0A0\uC9DC"
  - id: Utxt_KR_21
    text: Today's Mission
    info: "\uC624\uB298\uC758 \uBBF8\uC158"
  - id: Utxt_KR_22
    text: Today's Mission
    info: "\uC624\uB298\uC758 \uBBF8\uC158 \uCD5C\uC0C1\uB2E8 \uD14D\uC2A4\uD2B8"
  - id: Utxt_KR_23
    text: Confirm
    info: "\uC624\uB298\uC758 \uBBF8\uC158 \uD655\uC778 \uBC84\uD2BC"
  - id: Utxt_KR_24
    text: THE OFFICIAL LOG
    info: "\uC131\uACF5 UI \uCD5C\uC0C1\uB2E8 \uD14D\uC2A4\uD2B8"
  - id: Utxt_KR_25
    text: 'Officer Name: Etan Walker'
    info: "\uADFC\uBB34\uC790 \uBA85"
  - id: Utxt_KR_26
    text: Days Since Last Accident
    info: "\uBB34\uC0AC\uACE0 \uB0A0\uC9DC"
  - id: Utxt_KR_27
    text: 'Mission Result: Success'
    info: "\uBBF8\uC158 \uACB0\uACFC"
  - id: Utxt_KR_28
    text: See you tomorrow.
    info: "\uACC4\uC57D \uC5F0\uC7A5 \uB3C4\uC7A5 \uC0C1\uB2E8"
  - id: Utxt_KR_29
    text: Warden's Bag
    info: "\uACC4\uC57D \uC5F0\uC7A5 \uB3C4\uC7A5 \uD558\uB2E8"
  - id: Utxt_KR_30
    text: Next Day
    info: "\uB2E4\uC74C \uB0A0 \uC774\uB3D9 \uBC84\uD2BC"
  - id: Utxt_KR_31
    text: NOTICE OF TERMINATION
    info: "\uC2E4\uD328 UI \uCD5C\uC0C1\uB2E8 \uD14D\uC2A4\uD2B8"
  - id: Utxt_KR_32
    text: 'Staff Name: Etan Walker'
    info: "\uADFC\uBB34\uC790 \uBA85"
  - id: Utxt_KR_33
    text: Days Without Incident
    info: "\uADFC\uBB34\uC77C \uC218"
  - id: Utxt_KR_34
    text: Reason for Termination
    info: "\uD574\uACE0 \uC0AC\uC720 \uD14D\uC2A4\uD2B8"
  - id: Utxt_KR_35
    text: You are hereby terminated for the reasons above.
    info: "\uADC0\uD558\uB97C \uD574\uACE0\uD569\uB2C8\uB2E4."
  - id: Utxt_KR_36
    text: Notice of Termination
    info: "\uD574\uACE0 \uD1B5\uC9C0 \uB3C4\uC7A5 \uC0C1\uB2E8"
  - id: Utxt_KR_37
    text: Warden's Bag
    info: "\uD574\uACE0 \uD1B5\uC9C0 \uB3C4\uC7A5 \uD558\uB2E8"
  - id: Utxt_KR_38
    text: Restart Shift
    info: "\uADFC\uBB34 \uC7AC\uC2DC\uC791 \uBC84\uD2BC(\uBBF8\uC158 \uC2E4\uD328
      UI) | \uADFC\uBB34 \uC7AC\uC2DC\uC791 \uBC84\uD2BC(\uAC8C\uC784 \uC624\uBC84
      UI)"
  - id: Utxt_KR_39
    text: Pause Work
    info: "\uC77C\uC2DC \uC815\uC9C0 \uCC3D \uBB38\uAD6C"
  - id: Utxt_KR_40
    text: Resume Work
    info: "\uACC4\uC18D\uD558\uAE30 \uBC84\uD2BC"
  - id: Utxt_KR_41
    text: Stop Work
    info: "\uD0C0\uC774\uD2C0 \uC774\uB3D9 \uBC84\uD2BC"
  - id: Utxt_KR_42
    text: Hold right-click and move to rotate the object.
    info: "\uC0C1\uC138\uBCF4\uAE30 \uC0C1\uB2E8 \uC548\uB0B4 \uBB38\uAD6C(\uD074\uB9AD
      x)"
  - id: Utxt_KR_43
    text: Release right-click to stop rotating.
    info: "\uC0C1\uC138\uBCF4\uAE30 \uC0C1\uB2E8 \uC548\uB0B4 \uBB38\uAD6C(\uD074\uB9AD
      o)"
  - id: Utxt_KR_44
    text: Left-click to interact with objects.
    info: "\uBB3C\uCCB4 \uC544\uB798 \uC0C1\uD638\uC791\uC6A9 \uC548\uB0B4 \uBB38\uAD6C"
  - id: Utxt_KR_45
    text: Press [E] to exit inspection
    info: "\uC0C1\uC138\uBCF4\uAE30 \uC885\uB8CC \uBB38\uAD6C"
  - id: Utxt_KR_46
    text: Game Over
    info: "\uAC8C\uC784 \uC624\uBC84 \uBB38\uAD6C"
  - id: Utxt_KR_47
    text: Would you like to report<br>the patrol results?
    info: "\uBCF4\uACE0 \uC804 \uD655\uC778 UI"
  - id: Utxt_KR_48
    text: You must report after the patrol.
    info: "\uBE0C\uB9AC\uD551 \uD398\uC774\uC988 \uBCF4\uACE0 \uC2DC\uB3C4 \uC2DC
      \uBA54\uC2DC\uC9C0"
  - id: Utxt_KR_49
    text: 'Skip Tutorial: [Q]'
    info: "\uD29C\uD1A0\uB9AC\uC5BC \uC2A4\uD0B5 Q"
  - id: Utxt_KR_50
    text: 'Start Tutorial: [E]'
    info: "\uD29C\uD1A0\uB9AC\uC5BC \uC9C4\uD589 E"
  - id: Utxt_KR_51
    text: You must receive a mission<br>from the Warden first!
    info: "\uACBD\uACE0 \uBA54\uC2DC\uC9C0: \uAD50\uB3C4\uC18C\uC7A5\uACFC \uB300\uD654
      \uC804 \uACC4\uB2E8 \uBB38\uACFC \uC0C1\uD638\uC791\uC6A9\uD560 \uACBD\uC6B0"
  - id: Utxt_KR_52
    text: Start Patrol
    info: "\uACBD\uACE0 \uBA54\uC2DC\uC9C0: \uC21C\uCC30 \uC2DC\uC791"
  - id: Utxt_KR_53
    text: You can move after closing all cell doors!
    info: "\uACBD\uACE0 \uBA54\uC2DC\uC9C0: \uAC10\uBC29 \uBB38\uC774 \uC5F4\uB9B0
      \uC0C1\uD0DC\uB85C \uACC4\uB2E8 \uBB38\uACFC \uC0C1\uD638\uC791\uC6A9\uD560
      \uACBD\uC6B0"
  - id: Utxt_KR_54
    text: Close the open cell doors first!
    info: "\uACBD\uACE0 \uBA54\uC2DC\uC9C0: \uAC10\uBC29 \uBB38\uC774 \uC5F4\uB9B0
      \uC0C1\uD0DC\uB85C \uB2E4\uB978 \uAC10\uBC29 \uBB38\uC744 \uC5F4\uB824\uACE0
      \uD560 \uACBD\uC6B0"
  - id: Utxt_KR_55
    text: You can't close cell doors during combat!
    info: "\uACBD\uACE0 \uBA54\uC2DC\uC9C0: \uC804\uD22C \uC911 \uAC10\uBC29 \uBB38\uC744
      \uB2EB\uC73C\uB824\uACE0 \uD560 \uACBD\uC6B0"
  - id: Utxt_KR_56
    text: This room is locked.
    info: "\uACBD\uACE0 \uBA54\uC2DC\uC9C0: \uBB38\uC774 \uC7A0\uACA8 \uC788\uC744
      \uACBD\uC6B0"
  - id: Utxt_KR_57
    text: Can't close the door from the inside.
    info: "\uACBD\uACE0 \uBA54\uC2DC\uC9C0: \uB0B4\uBD80\uC5D0\uC11C \uBB38\uC744
      \uB2EB\uC73C\uB824\uACE0 \uD588\uC744 \uACBD\uC6B0"
  - id: Utxt_KR_58
    text: No save data found.
    info: "\uACBD\uACE0 \uBA54\uC2DC\uC9C0: \uC800\uC7A5\uB41C \uB370\uC774\uD130\uAC00
      \uC5C6\uC744 \uACBD\uC6B0"
