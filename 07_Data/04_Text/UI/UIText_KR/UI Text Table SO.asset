    info: "\uD574\uACE0 \uD1B5\uC9C0 \uB3C4\uC7A5 \uD558\uB2E8"
  - id: Utxt_KR_38
    text: "\uADFC\uBB34 \uC7AC\uC2DC\uC791"
    info: "\uADFC\uBB34 \uC7AC\uC2DC\uC791 \uBC84\uD2BC(\uBBF8\uC158 \uC2E4\uD328
      UI) | \uADFC\uBB34 \uC7AC\uC2DC\uC791 \uBC84\uD2BC(\uAC8C\uC784 \uC624\uBC84
      UI)"
  - id: Utxt_KR_39
    text: "\uC5C5\uBB34 \uC77C\uC2DC \uC911\uB2E8"
    info: "\uC77C\uC2DC \uC815\uC9C0 \uCC3D \uBB38\uAD6C"
  - id: Utxt_KR_40
    text: "\uC5C5\uBB34 \uC7AC\uAC1C"
    info: "\uACC4\uC18D\uD558\uAE30 \uBC84\uD2BC"
  - id: Utxt_KR_41
    text: "\uC5C5\uBB34 \uC911\uB2E8"
    info: "\uD0C0\uC774\uD2C0 \uC774\uB3D9 \uBC84\uD2BC"
  - id: Utxt_KR_42
    text: "\uB9C8\uC6B0\uC2A4 \uC624\uB978\uCABD \uBC84\uD2BC\uC744 \uB204\uB978
      \uCC44\uB85C \uC774\uB3D9\uD558\uBA74 \uBB3C\uCCB4\uB97C \uD68C\uC804\uC2DC\uD0AC
      \uC218 \uC788\uC2B5\uB2C8\uB2E4"
    info: "\uC0C1\uC138\uBCF4\uAE30 \uC0C1\uB2E8 \uC548\uB0B4 \uBB38\uAD6C(\uD074\uB9AD
      x)"
  - id: Utxt_KR_43
    text: "\uB9C8\uC6B0\uC2A4 \uC624\uB978\uCABD \uBC84\uD2BC\uC744 \uB5C4 \uACBD\uC6B0
      \uD68C\uC804\uC744 \uBA48\uCDA5\uB2C8\uB2E4."
    info: "\uC0C1\uC138\uBCF4\uAE30 \uC0C1\uB2E8 \uC548\uB0B4 \uBB38\uAD6C(\uD074\uB9AD
      o)"
  - id: Utxt_KR_44
    text: "\uB9C8\uC6B0\uC2A4 \uC67C\uCABD \uBC84\uD2BC\uC744 \uB20C\uB7EC \uBB3C\uCCB4\uC640
      \uC0C1\uD638\uC791\uC6A9\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    info: "\uBB3C\uCCB4 \uC544\uB798 \uC0C1\uD638\uC791\uC6A9 \uC548\uB0B4 \uBB38\uAD6C"
  - id: Utxt_KR_45
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uC0C1\uC138\uBCF4\uAE30 \uC885\uB8CC"
    info: "\uC0C1\uC138\uBCF4\uAE30 \uC885\uB8CC \uBB38\uAD6C"
  - id: Utxt_KR_46
    text: "\uAC8C\uC784 \uC624\uBC84"
    info: "\uAC8C\uC784 \uC624\uBC84 \uBB38\uAD6C"
  - id: Utxt_KR_47
    text: "\uC21C\uCC30 \uACB0\uACFC\uB97C \uBCF4\uACE0\uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    info: "\uBCF4\uACE0 \uC804 \uD655\uC778 UI"
  - id: Utxt_KR_48
    text: "\uC21C\uCC30 \uD6C4\uC5D0 \uBCF4\uACE0\uD574\uC57C \uD55C\uB2E4."
    info: "\uBE0C\uB9AC\uD551 \uD398\uC774\uC988 \uBCF4\uACE0 \uC2DC\uB3C4 \uC2DC
      \uBA54\uC2DC\uC9C0"
  - id: Utxt_KR_49
    text: "\uD29C\uD1A0\uB9AC\uC5BC \uC2A4\uD0B5: Q"
    info: "\uD29C\uD1A0\uB9AC\uC5BC \uC2A4\uD0B5 Q"
  - id: Utxt_KR_50
    text: "\uD29C\uD1A0\uB9AC\uC5BC \uC9C4\uD589: E"
    info: "\uD29C\uD1A0\uB9AC\uC5BC \uC9C4\uD589 E"
  - id: Utxt_KR_51
    text: "\uBA3C\uC800 \uAD50\uB3C4\uC18C\uC7A5\uC5D0\uAC8C \uBBF8\uC158\uC744 \uBC1B\uC544\uC57C
      \uD569\uB2C8\uB2E4!"
    info: "\uACBD\uACE0 \uBA54\uC2DC\uC9C0: \uAD50\uB3C4\uC18C\uC7A5\uACFC \uB300\uD654
      \uC804 \uACC4\uB2E8 \uBB38\uACFC \uC0C1\uD638\uC791\uC6A9\uD560 \uACBD\uC6B0"
  - id: Utxt_KR_52
    text: "\uC21C\uCC30 \uC2DC\uC791"
    info: "\uACBD\uACE0 \uBA54\uC2DC\uC9C0: \uC21C\uCC30 \uC2DC\uC791"
  - id: Utxt_KR_53
    text: "\uBAA8\uB4E0 \uAC10\uBC29 \uBB38\uC744 \uB2EB\uC740 \uD6C4 \uC774\uB3D9\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4!"
    info: "\uACBD\uACE0 \uBA54\uC2DC\uC9C0: \uAC10\uBC29 \uBB38\uC774 \uC5F4\uB9B0
      \uC0C1\uD0DC\uB85C \uACC4\uB2E8 \uBB38\uACFC \uC0C1\uD638\uC791\uC6A9\uD560
      \uACBD\uC6B0"
  - id: Utxt_KR_54
    text: "\uC774\uBBF8 \uC5F4\uB824 \uC788\uB294 \uAC10\uBC29 \uBB38\uC744 \uBA3C\uC800
      \uB2EB\uC544\uC57C \uD569\uB2C8\uB2E4!"
    info: "\uACBD\uACE0 \uBA54\uC2DC\uC9C0: \uAC10\uBC29 \uBB38\uC774 \uC5F4\uB9B0
      \uC0C1\uD0DC\uB85C \uB2E4\uB978 \uAC10\uBC29 \uBB38\uC744 \uC5F4\uB824\uACE0
      \uD560 \uACBD\uC6B0"
  - id: Utxt_KR_55
    text: "\uC804\uD22C \uC911\uC5D0\uB294 \uAC10\uBC29 \uBB38\uC744 \uB2EB\uC744
      \uC218 \uC5C6\uC2B5\uB2C8\uB2E4!"
    info: "\uACBD\uACE0 \uBA54\uC2DC\uC9C0: \uC804\uD22C \uC911 \uAC10\uBC29 \uBB38\uC744
      \uB2EB\uC73C\uB824\uACE0 \uD560 \uACBD\uC6B0"
  - id: Utxt_KR_56
    text: "\uC7A0\uACA8\uC788\uB294 \uBC29\uC785\uB2C8\uB2E4."
    info: "\uACBD\uACE0 \uBA54\uC2DC\uC9C0: \uBB38\uC774 \uC7A0\uACA8 \uC788\uC744
      \uACBD\uC6B0"
  - id: Utxt_KR_57
    text: "\uB0B4\uBD80\uC5D0\uC120 \uBB38\uC744 \uB2EB\uC744 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
    info: "\uACBD\uACE0 \uBA54\uC2DC\uC9C0: \uB0B4\uBD80\uC5D0\uC11C \uBB38\uC744
      \uB2EB\uC73C\uB824\uACE0 \uD588\uC744 \uACBD\uC6B0"
  - id: Utxt_KR_58
    text: "\uC800\uC7A5\uB41C \uB370\uC774\uD130\uAC00 \uC5C6\uC2B5\uB2C8\uB2E4."
    info: "\uACBD\uACE0 \uBA54\uC2DC\uC9C0: \uC800\uC7A5\uB41C \uB370\uC774\uD130\uAC00
      \uC5C6\uC744 \uACBD\uC6B0"
