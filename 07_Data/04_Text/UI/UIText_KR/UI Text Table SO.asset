    text: "\uBBF8\uC158 \uACB0\uACFC: \uC131\uACF5"
    info: "\uBBF8\uC158 \uACB0\uACFC"
  - id: Utxt_KR_28
    text: "\uB0B4\uC77C \uB2E4\uC2DC \uBD59\uACA0\uC2B5\uB2C8\uB2E4."
