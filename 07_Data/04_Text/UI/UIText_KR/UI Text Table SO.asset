    info: "\uADFC\uBB34\uC790 \uBA85"
  - id: Utxt_KR_33
    text: "\uADFC\uBB34\uC77C \uC218:"
    info: "\uADFC\uBB34\uC77C \uC218"
  - id: Utxt_KR_34
    text: "\uD574\uACE0 \uC0AC\uC720"
    info: "\uD574\uACE0 \uC0AC\uC720 \uD14D\uC2A4\uD2B8"
  - id: Utxt_KR_35
    text: "\uC0C1\uAE30 \uC0AC\uC720\uB85C \uADC0\uD558\uB97C \uD574\uACE0\uD569\uB2C8\uB2E4."
    info: "\uADC0\uD558\uB97C \uD574\uACE0\uD569\uB2C8\uB2E4."
  - id: Utxt_KR_36
    text: "\uD574\uACE0\uB97C \uD1B5\uC9C0\uD569\uB2C8\uB2E4"
    info: "\uD574\uACE0 \uD1B5\uC9C0 \uB3C4\uC7A5 \uC0C1\uB2E8"
  - id: Utxt_KR_37
