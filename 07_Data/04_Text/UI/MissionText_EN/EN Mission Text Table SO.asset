%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9c91c1e9404041849bcfdecd98a4c9b2, type: 3}
  m_Name: EN Mission Text Table SO
  m_EditorClassIdentifier: 
  missionTextSets:
  - missionIndex: 1
    texts:
    - role: 0
      text: Suppress all the noisy prisoners!
      info: "\uC624\uB298\uC758 \uBBF8\uC158 UI \uD0C0\uC774\uD2C0 01 | \uBBF8\uC158
        \uC131\uACF5 UI \uD0C0\uC774\uD2C0 01"
    - role: 1
      text: 'Prisoners are making a racket.

        If we let them be,

        they''ll
        start pulling nonsense

        under the cover of the noise.

        Suppress
        all noisy prisoners.'
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uC0C1\uC138 \uB0B4\uC6A9 01"
    - role: 2
      text: Suppress 6 noisy prisoners
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uC644\uB8CC \uC870\uAC74 01"
    - role: 3
      text: Noisy Prisoner
      info: "\uBBF8\uC158 \uC9C4\uD589\uB3C4 \uD14D\uC2A4\uD2B8 01"
    - role: 4
      text: Failed to silence the noisy prisoners
      info: "\uD574\uACE0 \uC0AC\uC720 \uC0C1\uC138 \uB0B4\uC6A9 01"
  - missionIndex: 2
    texts:
    - role: 0
      text: 'Confiscate all weapons

        hidden in the cells!'
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uD0C0\uC774\uD2C0 02 | \uBBF8\uC158
        \uC131\uACF5 UI \uD0C0\uC774\uD2C0 02"
    - role: 1
      text: 'Prisoners have hidden weapons in their cells.

        An accident is
        bound to happen

        if these weapons aren''t confiscated.

        Confiscate
        all hidden weapons.'
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uC0C1\uC138 \uB0B4\uC6A9 02"
    - role: 2
      text: Confiscate 7 weapons hidden in cells
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uC644\uB8CC \uC870\uAC74 02"
    - role: 3
      text: 'Confiscated

        Weapons'
      info: "\uBBF8\uC158 \uC9C4\uD589\uB3C4 \uD14D\uC2A4\uD2B8 02"
    - role: 4
      text: 'An accident occurred

        because you failed to confiscate

        all
        the hidden weapons.'
      info: "\uD574\uACE0 \uC0AC\uC720 \uC0C1\uC138 \uB0B4\uC6A9 02"
  - missionIndex: 3
    texts:
    - role: 0
      text: Suppress all the freaks acting out!
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uD0C0\uC774\uD2C0 03 | \uBBF8\uC158
        \uC131\uACF5 UI \uD0C0\uC774\uD2C0 03"
    - role: 1
      text: 'The new arrivals are acting strange.

        Search every cell

        and
        suppress any freaks caught acting out.'
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uC0C1\uC138 \uB0B4\uC6A9 03"
    - role: 2
      text: Suppress all 6 prisoners acting out
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uC644\uB8CC \uC870\uAC74 03"
    - role: 3
      text: 'Suppressed

        Prisoners'
      info: "\uBBF8\uC158 \uC9C4\uD589\uB3C4 \uD14D\uC2A4\uD2B8 03"
    - role: 4
      text: 'You ignored the ones acting out,

        and now the entire sector
        has lost it.'
      info: "\uD574\uACE0 \uC0AC\uC720 \uC0C1\uC138 \uB0B4\uC6A9 03"
  - missionIndex: 4
    texts:
    - role: 0
      text: Find 'Frank'!
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uD0C0\uC774\uD2C0 04 | \uBBF8\uC158
        \uC131\uACF5 UI \uD0C0\uC774\uD2C0 04"
    - role: 1
      text: 'Senior Guard Frank, hasn''t returned from patrol

        Head down
        to the prison and find him.'
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uC0C1\uC138 \uB0B4\uC6A9 04"
    - role: 2
      text: Find Frank and suppress the impostors.
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uC644\uB8CC \uC870\uAC74 04"
    - role: 3
      text: 'Suppressed

        Impostors'
      info: "\uBBF8\uC158 \uC9C4\uD589\uB3C4 \uD14D\uC2A4\uD2B8 04"
    - role: 4
      text: 'Failed to distinguish the real senior guard

        from the disguised
        prisoner.'
      info: "\uD574\uACE0 \uC0AC\uC720 \uC0C1\uC138 \uB0B4\uC6A9 04"
  - missionIndex: 5
    texts:
    - role: 0
      text: Confiscate all contraband!
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uD0C0\uC774\uD2C0 05 | \uBBF8\uC158
        \uC131\uACF5 UI \uD0C0\uC774\uD2C0 05"
    - role: 1
      text: 'Prisoners always find a way to smuggle junk in.

        We can''t stop
        them, but can''t ignore it either.

        Confiscate all the contraband!'
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uC0C1\uC138 \uB0B4\uC6A9 05"
    - role: 2
      text: Confiscate 7 contraband items
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uC644\uB8CC \uC870\uAC74 05"
    - role: 3
      text: Seized Contraband
      info: "\uBBF8\uC158 \uC9C4\uD589\uB3C4 \uD14D\uC2A4\uD2B8 05"
    - role: 4
      text: 'You let contraband circulate,

        completely disrupting the prison''s
        discipline.'
      info: "\uD574\uACE0 \uC0AC\uC720 \uC0C1\uC138 \uB0B4\uC6A9 05"
  - missionIndex: 6
    texts:
    - role: 0
      text: Find the firearm smuggler!
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uD0C0\uC774\uD2C0 06 | \uBBF8\uC158
        \uC131\uACF5 UI \uD0C0\uC774\uD2C0 06"
    - role: 1
      text: 'One of the gang members smuggled a gun.

        Talk to the three suspects,

        find
        the one who''s lying.

        And report the culprit to Frank.'
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uC0C1\uC138 \uB0B4\uC6A9 06"
    - role: 2
      text: 'Identify the firearm smuggler

        and tell Frank who it is.'
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uC644\uB8CC \uC870\uAC74 06"
    - role: 3
      text: Identify Culprit
      info: "\uBBF8\uC158 \uC9C4\uD589\uB3C4 \uD14D\uC2A4\uD2B8 06"
    - role: 4
      text: 'The number of firearms in the prison increased

        because you
        were far off the mark'
      info: "\uD574\uACE0 \uC0AC\uC720 \uC0C1\uC138 \uB0B4\uC6A9 06"
  - missionIndex: 7
    texts:
    - role: 0
      text: Suppress the planned riot!
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uD0C0\uC774\uD2C0 07 | \uBBF8\uC158
        \uC131\uACF5 UI \uD0C0\uC774\uD2C0 07"
    - role: 1
      text: 'A rat brought important intelligence.

        that the inmates are
        planning a massive riot.

        Beat them all into submission

        before
        they can start anything'
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uC0C1\uC138 \uB0B4\uC6A9 07"
    - role: 2
      text: Suppress all prisoners
      info: "\uC624\uB298\uC758 \uBBF8\uC158 \uC644\uB8CC \uC870\uAC74 07"
    - role: 3
      text: 'Suppressed

        Rioters'
      info: "\uBBF8\uC158 \uC9C4\uD589\uB3C4 \uD14D\uC2A4\uD2B8 07"
    - role: 4
      text: 'You failed to stop the planned riot,

        throwing the prison into
        total chaos.'
      info: "\uD574\uACE0 \uC0AC\uC720 \uC0C1\uC138 \uB0B4\uC6A9 07"
