  entries:
  - id: Ptxt_KR_Object_01
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uC120\uC784 \uAD50\uB3C4\uAD00\uACFC \uB300\uD654\uD558\uAE30"
    info: "\uC120\uC784 \uAD50\uB3C4\uAD00 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_02
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uAD50\uB3C4\uC18C\uC7A5\uACFC \uB300\uD654\uD558\uAE30"
    info: "\uAD50\uB3C4\uC18C\uC7A5 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_03
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uC8C4\uC218\uC640 \uB300\uD654\uD558\uAE30"
    info: "\uC8C4\uC218 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8(\uBBF8\uC158
      06)"
  - id: Ptxt_KR_Object_04
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uAD50\uB3C4\uC18C \uC785\uAD6C \uBB38 \uC5F4\uAE30"
    info: "\uAD50\uB3C4\uC18C \uC785\uAD6C \uBB38 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_05
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uCE90\uBE44\uB2DB \uC5F4\uAE30"
    info: "\uCE90\uBE44\uB2DB \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_06
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uCE90\uBE44\uB2DB \uB2EB\uAE30"
    info: "\uCE90\uBE44\uB2DB \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_07
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uACC4\uB2E8 \uBB38 \uC5F4\uAE30"
    info: "\uACC4\uB2E8 \uBB38 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_08
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uAC10\uBC29 \uBB38 \uC5F4\uAE30"
    info: "\uAC10\uBC29 \uBB38 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8 01"
  - id: Ptxt_KR_Object_09
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uAC10\uBC29 \uBB38 \uB2EB\uAE30"
    info: "\uAC10\uBC29 \uBB38 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8 02"
  - id: Ptxt_KR_Object_10
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uBCC0\uAE30 \uCEE4\uBC84 \uC62C\uB9AC\uAE30"
    info: "\uBCC0\uAE30 \uCEE4\uBC84 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_11
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uD3EC\uC2A4\uD130 \uB5BC\uAE30"
    info: "\uD3EC\uC2A4\uD130 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_12
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uD734\uC9C0\uD1B5 \uC790\uC138\uD788 \uD655\uC778\uD558\uAE30"
    info: "\uD734\uC9C0\uD1B5 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_13
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uCE6B\uC194 \uCEF5 \uC790\uC138\uD788 \uD655\uC778\uD558\uAE30"
    info: "\uCE6B\uC194 \uCEF5 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_14
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uC131\uACBD \uC790\uC138\uD788 \uD655\uC778\uD558\uAE30"
    info: "\uC131\uACBD \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_15
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uB364\uBCA8 \uC790\uC138\uD788 \uD655\uC778\uD558\uAE30"
    info: "\uB364\uBCA8 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_16
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uC2E0\uBC1C \uC790\uC138\uD788 \uD655\uC778\uD558\uAE30"
    info: "\uC2E0\uBC1C \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_17
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uBE75 \uB369\uC5B4\uB9AC \uC790\uC138\uD788
      \uD655\uC778\uD558\uAE30"
    info: "\uBE75 \uB369\uC5B4\uB9AC \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_18
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uBCA0\uAC1C \uB4E4\uAE30"
    info: "\uBCA0\uAC1C \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8 01"
  - id: Ptxt_KR_Object_19
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uBCA0\uAC1C \uB0B4\uB824\uB193\uAE30"
    info: "\uBCA0\uAC1C \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8 02"
  - id: Ptxt_KR_Object_20
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uD658\uD48D\uAD6C \uCEE4\uBC84 \uB4E4\uAE30"
    info: "\uD658\uD48D\uAD6C \uCEE4\uBC84 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8
      01"
  - id: Ptxt_KR_Object_21
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uD658\uD48D\uAD6C \uCEE4\uBC84 \uB0B4\uB824\uB193\uAE30"
    info: "\uD658\uD48D\uAD6C \uCEE4\uBC84 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8
      02"
  - id: Ptxt_KR_Object_22
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uD0C0\uC77C \uB4E4\uAE30"
    info: "\uD0C0\uC77C \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8 01"
  - id: Ptxt_KR_Object_23
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uD0C0\uC77C \uB0B4\uB824\uB193\uAE30"
    info: "\uD0C0\uC77C \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8 02"
  - id: Ptxt_KR_Object_24
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uC6D0\uD310 \uB4E4\uAE30"
    info: "\uC6D0\uD310 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8 01"
  - id: Ptxt_KR_Object_25
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uC6D0\uD310 \uB0B4\uB824\uB193\uAE30"
    info: "\uC6D0\uD310 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8 02"
  - id: Ptxt_KR_Object_26
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uD654\uBD84 \uB4E4\uAE30"
    info: "\uD654\uBD84 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8 01"
  - id: Ptxt_KR_Object_27
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uD654\uBD84 \uB0B4\uB824\uB193\uAE30"
    info: "\uD654\uBD84 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8 02"
  - id: Ptxt_KR_Object_28
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uBCBD\uB3CC \uB4E4\uAE30"
    info: "\uBCBD\uB3CC \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8 01"
  - id: Ptxt_KR_Object_29
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uBCBD\uB3CC \uB0B4\uB824\uB193\uAE30"
    info: "\uBCBD\uB3CC \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8 02"
  - id: Ptxt_KR_Object_30
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uB9DD\uCE58 \uC555\uC218\uD558\uAE30"
    info: "\uB9DD\uCE58 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_31
    text: "\uB9C8\uC6B0\uC2A4 \uC67C\uCABD \uBC84\uD2BC\uC744 \uB20C\uB7EC \uB2E8\uAC80
      \uC555\uC218\uD558\uAE30"
    info: "\uB2E8\uAC80 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_32
    text: "\uB9C8\uC6B0\uC2A4 \uC67C\uCABD \uBC84\uD2BC\uC744 \uB20C\uB7EC \uCE6B\uC194
      \uC555\uC218\uD558\uAE30"
    info: "\uCE6B\uC194 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_33
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uC220\uBCD1 \uC555\uC218\uD558\uAE30"
    info: "\uC220\uBCD1 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_34
    text: "\uB9C8\uC6B0\uC2A4 \uC67C\uCABD \uBC84\uD2BC\uC744 \uB20C\uB7EC \uC1A1\uACF3
      \uC555\uC218\uD558\uAE30"
    info: "\uC1A1\uACF3 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_35
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uB77C\uC774\uD130 \uC555\uC218\uD558\uAE30"
    info: "\uB77C\uC774\uD130 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_36
    text: "\uB9C8\uC6B0\uC2A4 \uC67C\uCABD \uBC84\uD2BC\uC744 \uB20C\uB7EC \uB108\uD074
      \uC555\uC218\uD558\uAE30"
    info: "\uB108\uD074 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_37
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uC131\uC778 \uC7A1\uC9C0 \uC555\uC218\uD558\uAE30"
    info: "\uC131\uC778 \uC7A1\uC9C0 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_38
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uD2B8\uB7FC\uD504 \uCE74\uB4DC \uC555\uC218\uD558\uAE30"
    info: "\uD2B8\uB7FC\uD504 \uCE74\uB4DC \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_39
    text: "\uB9C8\uC6B0\uC2A4 \uC67C\uCABD \uBC84\uD2BC\uC744 \uB20C\uB7EC \uC21F\uAC00\uB77D
      \uCE7C \uC555\uC218\uD558\uAE30"
    info: "\uC21F\uAC00\uB77D \uCE7C \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_40
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uB2F4\uBC30\uAC11 \uC555\uC218\uD558\uAE30"
    info: "\uB2F4\uBC30\uAC11 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_41
    text: "\uB9C8\uC6B0\uC2A4 \uC67C\uCABD \uBC84\uD2BC\uC744 \uB20C\uB7EC \uB098\uC774\uD504
      \uC555\uC218\uD558\uAE30"
    info: "\uB098\uC774\uD504 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_42
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uC9C0\uD3D0 \uBB49\uCE58 \uC555\uC218\uD558\uAE30"
    info: "\uC9C0\uD3D0 \uBB49\uCE58 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_43
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uAC04\uC218\uBCF5 \uC555\uC218\uD558\uAE30"
    info: "\uAC04\uC218\uBCF5 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_44
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uBBF8\uBBF8\uC640 \uB300\uD654\uD558\uAE30"
    info: "\uBBF8\uBBF8 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_45
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uBE44\uB204 \uC90D\uAE30"
    info: "\uBE44\uB204 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8"
  - id: Ptxt_KR_Object_46
    text: "E \uD0A4\uB97C \uB20C\uB7EC \uC2A4\uB9C8\uD2B8\uD3F0 \uC555\uC218\uD558\uAE30"
