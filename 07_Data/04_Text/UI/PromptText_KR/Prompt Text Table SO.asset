    text: "E \uD0A4\uB97C \uB20C\uB7EC \uBC15\uC2A4 \uB0B4\uB824\uB193\uAE30"
    info: "\uBC15\uC2A4 \uD504\uB86C\uD504\uD2B8 \uD14D\uC2A4\uD2B8 02"
