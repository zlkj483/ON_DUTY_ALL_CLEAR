MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 61d01197186f2f44b932089beb3014be, type: 3}
  m_Name: Tutorial Text Table EN SO
  m_EditorClassIdentifier: 
  entries:
  - id: Ttxt_M_01
    text: Talk to Senior Guard, Frank
    info: "\uD29C\uD1A0\uB9AC\uC5BC \uBBF8\uC158 \uD14D\uC2A4\uD2B8 01"
  - id: Ttxt_M_02
    text: "Clear the box \nin front of the cabinet"
    info: "\uD29C\uD1A0\uB9AC\uC5BC \uBBF8\uC158 \uD14D\uC2A4\uD2B8 02"
  - id: Ttxt_M_03
    text: 'Open the cabinet.

      Equip nightstick'
    info: "\uD29C\uD1A0\uB9AC\uC5BC \uBBF8\uC158 \uD14D\uC2A4\uD2B8 03"
  - id: Ttxt_M_04
    text: Attack Frank
    info: "\uD29C\uD1A0\uB9AC\uC5BC \uBBF8\uC158 \uD14D\uC2A4\uD2B8 04"
  - id: Ttxt_M_05
    text: 'Examine the Bible

      on the table.'
    info: "\uD29C\uD1A0\uB9AC\uC5BC \uBBF8\uC158 \uD14D\uC2A4\uD2B8 05"
  - id: Ttxt_M_06
    text: Listen to Frank.
    info: "\uD29C\uD1A0\uB9AC\uC5BC \uBBF8\uC158 \uD14D\uC2A4\uD2B8 06"
  - id: Ttxt_G_01
    text: Use [WASD] to move.
    info: "\uAC00\uC774\uB4DC WASD"
  - id: Ttxt_G_02
    text: Hold [SHIFT] while moving to sprint.
    info: "\uAC00\uC774\uB4DC SHIFT"
  - id: Ttxt_G_03
    text: Use [CTRL] to crouch or stand up.
    info: "\uAC00\uC774\uB4DC CTRL"
  - id: Ttxt_G_04
    text: Press [E] to interact with objects.
    info: "\uAC00\uC774\uB4DC E"
  - id: Ttxt_G_05
    text: Press [ESC] to open the pause menu.
    info: "\uAC00\uC774\uB4DC ESC"
  - id: Ttxt_G_06
    text: Press [Q] to skip dialogue
    info: "\uAC00\uC774\uB4DC Q"
  - id: Ttxt_G_07
    text: Move the [Mouse] to look around.
    info: "\uAC00\uC774\uB4DC \uB9C8\uC6B0\uC2A4"
  - id: Ttxt_G_08
    text: Click and drag [Right-Mouse-Button] to rotate objects while in detail view.
    info: "\uAC00\uC774\uB4DC Right Mouse Btn"
  - id: Ttxt_G_09
    text: Click [Left-Mouse-Button] to attack, or examine objects in detail view.
    info: "\uAC00\uC774\uB4DC Left Mouse Btn"
  - id: Ttxt_G_10
    text: Press ESC to off
    info: "\uAC00\uC774\uB4DC Q Skip"
