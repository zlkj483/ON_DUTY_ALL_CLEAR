  m_Name: Tutorial Text Table SO
  m_EditorClassIdentifier: 
  entries:
  - id: Ttxt_M_01
    text: "\uD654\uC774\uD2B8\uBCF4\uB4DC \uC55E\uC758 \uC120\uC784 \uAD50\uB3C4\uAD00\uC5D0\uAC8C
      \uB9D0 \uAC78\uAE30"
    info: "\uD29C\uD1A0\uB9AC\uC5BC \uBBF8\uC158 \uD14D\uC2A4\uD2B8 01"
  - id: Ttxt_M_02
    text: "\uCE90\uBE44\uB2DB \uC55E\uC758 \uBC15\uC2A4 \uCE58\uC6B0\uAE30"
    info: "\uD29C\uD1A0\uB9AC\uC5BC \uBBF8\uC158 \uD14D\uC2A4\uD2B8 02"
  - id: Ttxt_M_03
    text: "\uCE90\uBE44\uB2DB\uC744 \uC5F4\uACE0 \uC9C4\uC555 \uBD09 \uCC59\uAE30\uAE30"
    info: "\uD29C\uD1A0\uB9AC\uC5BC \uBBF8\uC158 \uD14D\uC2A4\uD2B8 03"
  - id: Ttxt_M_04
    text: "Frank\uC5D0\uAC8C \uC9C4\uC555 \uBD09\uC744 \uD718\uB458\uB7EC\uBCF4\uAE30"
    info: "\uD29C\uD1A0\uB9AC\uC5BC \uBBF8\uC158 \uD14D\uC2A4\uD2B8 04"
  - id: Ttxt_M_05
    text: "\uD14C\uC774\uBE14 \uC704\uC758 \uC131\uACBD \uCC45 \uD655\uC778\uD558\uAE30"
    info: "\uD29C\uD1A0\uB9AC\uC5BC \uBBF8\uC158 \uD14D\uC2A4\uD2B8 05"
  - id: Ttxt_M_06
    text: "Frank\uC758 \uC124\uBA85 \uB9C8\uC800 \uB4E3\uAE30"
    info: "\uD29C\uD1A0\uB9AC\uC5BC \uBBF8\uC158 \uD14D\uC2A4\uD2B8 06"
  - id: Ttxt_G_01
    text: "[WASD] \uD0A4\uB85C \uC774\uB3D9\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    info: "\uAC00\uC774\uB4DC WASD"
  - id: Ttxt_G_02
    text: "[SHIFT] \uD0A4\uB97C \uB204\uB974\uBA70 \uC774\uB3D9\uD558\uBA74 \uB2EC\uB9B4
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    info: "\uAC00\uC774\uB4DC SHIFT"
  - id: Ttxt_G_03
    text: "[CTRL] \uD0A4\uB97C \uB204\uB974\uBA74 \uC549\uAC70\uB098 \uC124 \uC218
      \uC788\uC2B5\uB2C8\uB2E4."
    info: "\uAC00\uC774\uB4DC CTRL"
  - id: Ttxt_G_04
    text: "[E] \uD0A4\uB97C \uB20C\uB7EC \uB2E4\uC591\uD55C \uC624\uBE0C\uC81D\uD2B8\uC640
      \uC0C1\uD638\uC791\uC6A9\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    info: "\uAC00\uC774\uB4DC E"
  - id: Ttxt_G_05
    text: "[ESC] \uD0A4\uB85C \uC77C\uC2DC\uC815\uC9C0 \uCC3D\uC744 \uC5F4 \uC218
      \uC788\uC2B5\uB2C8\uB2E4."
    info: "\uAC00\uC774\uB4DC ESC"
  - id: Ttxt_G_06
    text: "[Q] \uD0A4\uB85C \uB300\uD654\uB97C \uC2A4\uD0B5\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    info: "\uAC00\uC774\uB4DC Q"
  - id: Ttxt_G_07
    text: "\uB9C8\uC6B0\uC2A4\uB97C \uC6C0\uC9C1\uC5EC \uD50C\uB808\uC774\uC5B4 \uC2DC\uC120\uC744
      \uC870\uC791\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    info: "\uAC00\uC774\uB4DC \uB9C8\uC6B0\uC2A4"
  - id: Ttxt_G_08
    text: "\uC624\uB978\uCABD \uB9C8\uC6B0\uC2A4 \uD074\uB9AD \uBC0F \uB4DC\uB798\uADF8\uB85C
      \uC624\uBE0C\uC81D\uD2B8\uB97C \uD68C\uC804\uC2DC\uD0AC \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    info: "\uAC00\uC774\uB4DC Right Mouse Btn"
  - id: Ttxt_G_09
    text: "\uC67C\uCABD \uB9C8\uC6B0\uC2A4 \uD074\uB9AD\uC73C\uB85C \uACF5\uACA9\uC744
      \uD560 \uC218 \uC788\uC73C\uBA70, \uC0C1\uC138\uBCF4\uAE30\uC5D0\uC11C \uC0AC\uBB3C\uC744
      \uD655\uC778\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    info: "\uAC00\uC774\uB4DC Left Mouse Btn"
  - id: Ttxt_G_10
    text: "ESC\uB97C \uB20C\uB7EC \uC124\uBA85 \uB044\uAE30"
    info: "\uAC00\uC774\uB4DC Q Skip"
