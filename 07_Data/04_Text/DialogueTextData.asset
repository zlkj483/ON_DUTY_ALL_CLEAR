%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: b631211225048214fb47dd70a97c4c62, type: 3}
  m_Name: DialogueTextData
  m_EditorClassIdentifier: 
  textList:
  - key: DTxt_KR_T_01
    speaker: Frank
    mission: Tutorial
    type: Dialogue
    ko: "\uC654\uB098? \uB124\uAC00 \uC624\uB298\uBD80\uD130 \uAD6C\uB97C \uC2E0\uC785\uC774\uAD70."
    en: 
  - key: DTxt_KR_T_02
    speaker: Frank
    mission: Tutorial
    type: Dialogue
    ko: "\uC778\uC0C1\uC740\xB7\xB7\xB7 \uC4F8\uB9CC\uD558\uAD70. \uD558\uC9C0\uB9CC
      \uC911\uC694\uD55C \uAC74 \uADF8\uAC8C \uC544\uB2C8\uC57C."
    en: 
  - key: DTxt_KR_T_03
    speaker: Frank
    mission: Tutorial
    type: Dialogue
    ko: "\uAD50\uB3C4\uAD00\uC73C\uB85C \uADFC\uBB34\uD560 \uB54C \uAC00\uC7A5 \uC911\uC694\uD55C
      \uAC74 \u2018\uC6B4\u2019\uC774\uB791 \u2018\uB208\uCE58\u2019\uB2E4."
    en: 
  - key: DTxt_KR_T_04
    speaker: Frank
    mission: Tutorial
    type: Dialogue
    ko: "\uC77C\uB2E8, \uC6B4\uC774 \uC815\uB9D0 \uC911\uC694\uD574. \uC0AC\uACE0\uAC00
      \uC548 \uB098\uC57C \uD558\uAC70\uB4E0."
    en: 
  - key: DTxt_KR_T_05
    speaker: Frank
    mission: Tutorial
    type: Dialogue
    ko: "\uC798 \uBD10, \uC5EC\uAE30 \uD654\uC774\uD2B8\uBCF4\uB4DC \uBCF4\uC774\uC9C0?
      \uBB34\uC0AC\uACE0 \uBA70\uCE60 \uCC28\uB77C\uACE0 \uC801\uD600 \uC788\uC9C0?"
    en: 
  - key: DTxt_KR_T_06
    speaker: Frank
    mission: Tutorial
    type: BoardSee
    ko: "\uADF8\uB798. 0\uC77C\uC774\uB2E4. \uC5B4\uC81C\uB3C4 \uB108 \uAC19\uC740
      \uC560\uC1A1\uC774\uAC00 \uD55C \uB188 \uC2E4\uB824 \uB098\uAC14\uAC70\uB4E0."
    en: 
  - key: DTxt_KR_T_07
    speaker: Frank
    mission: Tutorial
    type: BoardSee
    ko: "\uC774 \uBE4C\uC5B4\uBA39\uC744 7\uAD6C\uC5ED\uC740 \uC0AC\uAC74 \uC0AC\uACE0\uAC00
      \uB04A\uC774\uC9C0 \uC54A\uC544."
    en: 
  - key: DTxt_KR_T_08
    speaker: Frank
    mission: Tutorial
    type: BoardSee
    ko: "\uB9E4\uC77C \uC0AC\uACE0\uAC00 \uD130\uC9C0\uACE0, \uC774\uD2C0\uB9CC \uD3C9\uD654\uB85C\uC6CC\uB3C4
      \uC624\uB798 \uAC04 \uAC70\uC9C0."
    en: 
  - key: DTxt_KR_T_09
    speaker: Frank
    mission: Tutorial
    type: BoardSee
    ko: "\uADF8\uB798\uC11C \uC6B0\uB9AC \uBAA9\uD45C\uB294 7\uC77C\uC774\uB2E4.
      \uB531 \uC77C\uC8FC\uC77C\uC774\uB77C\uACE0."
    en: 
  - key: DTxt_KR_T_10
    speaker: Frank
    mission: Tutorial
    type: BoardSee
    ko: "\uC624\uB298\uBD80\uD130 \uC0AC\uACE0 \uC5C6\uC774 7\uC77C\uC744 \uBC84\uD2F0\uBA74
      \uB10C \uC815\uADDC\uC9C1\uC774\uB2E4. \uD558\uC9C0\uB9CC"
    en: 
  - key: DTxt_KR_T_11
    speaker: Frank
    mission: Tutorial
    type: BoardSee
    ko: "\uB2E8 \uD55C \uBC88\uC774\uB77C\uB3C4 \uC0AC\uACE0\uAC00 \uD130\uC9C0\uBA74
      \uB10C \uADF8\uB0A0\uB85C \uC9D0 \uC2F8\uC11C \uB098\uAC00\uB294 \uAC70\uC57C."
    en: 
  - key: DTxt_KR_T_12
    speaker: Frank
    mission: Tutorial
    type: BoardSee
    ko: "\uADF8\uB9AC\uACE0 \uC6B0\uB9AC\uB294 \uB2E4\uC2DC 0\uC77C\uCC28\uBD80\uD130
      \uC2DC\uC791\uD558\uB294 \uAC70\uACE0. \uB0B4 \uB9D0 \uC774\uD574\uD588\uB098?"
    en: 
  - key: DTxt_KR_T_13
    speaker: Frank
    mission: Tutorial
    type: BoardSee
    ko: "\uC88B\uB2E4."
    en: 
  - key: DTxt_KR_T_14
    speaker: Frank
    mission: Tutorial
    type: BoardSee
    ko: "\uC77C\uB2E8 \uADFC\uBB34\uB97C \uC704\uD574 \uD544\uC694\uD55C \uAC83\uBD80\uD130
      \uCC59\uAE30\uC790\uACE0."
    en: 
  - key: DTxt_KR_T_15
    speaker: Frank
    mission: Tutorial
    type: BoardSee
    ko: "\uC77C\uB2E8 \uC9C4\uC555 \uBD09\uC744 \uC918\uC57C \uD558\uB294\uB370\xB7\xB7\xB7
      \uCE90\uBE44\uB2DB \uC55E\uC5D0 \uC0C1\uC790\uAC00 \uC313\uC5EC \uC788\uAD70."
    en: 
  - key: DTxt_KR_T_16
    speaker: Frank
    mission: Tutorial
    type: BoardSee
    ko: "\uC0C1\uC790 \uC55E\uC5D0\uC11C E \uD0A4\uB97C \uB204\uB974\uBA74 \uC0C1\uC790\uB97C
      \uB4E4 \uC218 \uC788\uACE0, \uB2E4\uC2DC E \uD0A4\uB97C \uB204\uB974\uBA74
      \uB0B4\uB824\uB193\uC744 \uC218 \uC788\uB2E4."
    en: 
  - key: DTxt_KR_T_17
    speaker: Frank
    mission: Tutorial
    type: BoxOpened
    ko: "\uB2E4\uB978 \uBB3C\uAC74\uC744 \uB4E4\uAC70\uB098 \uB0B4\uB824\uB193\uC744
      \uB54C\uB3C4 \uB9C8\uCC2C\uAC00\uC9C0\uB85C \uD558\uBA74 \uB41C\uB2E4."
    en: 
  - key: DTxt_KR_T_18
    speaker: Frank
    mission: Tutorial
    type: BoxOpened
    ko: "\uC790, \uC0C1\uC790\uB97C \uCE58\uC6E0\uC73C\uB2C8 \uCE90\uBE44\uB2DB\uC744
      \uC5F4\uACE0, \uADF8 \uC548\uC5D0 \uC788\uB294 \uC9C4\uC555 \uBD09\uC744 \uCC59\uACA8\uB77C.
      \uB458 \uB2E4 E\uD0A4\uB85C \uD560 \uC218 \uC788\uB2E4."
    en: 
  - key: DTxt_KR_T_19
    speaker: Frank
    mission: Tutorial
    type: BatonEquipped
    ko: "\uAD50\uB3C4\uAD00\uC774\uB77C\uBA74 \uC9C4\uC555 \uBD09\uC740 \uD544\uC218\uC9C0.
      \uC8C4\uC218 \uB188\uB4E4\uC740 \uB9D0\uB85C \uD574\uC11C\uB294 \uBABB \uC54C\uC544\uB4E3\uAC70\uB4E0."
    en: 
  - key: DTxt_KR_T_20
    speaker: Frank
    mission: Tutorial
    type: BatonEquipped
    ko: "\uB9C8\uC6B0\uC2A4 \uC67C\uCABD \uD0A4\uB97C \uB204\uB974\uBA74 \uACF5\uACA9\uD560
      \uC218 \uC788\uB2E4. \uC790, \uB098\uD55C\uD14C \uD55C \uBC88 \uD718\uB458\uB7EC\uBD10."
    en: 
  - key: DTxt_KR_T_21
    speaker: Frank
    mission: Tutorial
    type: NPCHit
    ko: "\uC0DD\uAC01\uBCF4\uB2E4\uB294 \uAF64 \uC798 \uCE58\uB294\uAD70. \uD2BC\uD2BC\uD55C
      \uB188\uB4E4\uB3C4 \uB124, \uB2E4\uC12F \uB300\uBA74 \uC81C\uC555\uD560 \uC218
      \uC788\uACA0\uC5B4."
    en: 
  - key: DTxt_KR_T_22
    speaker: Frank
    mission: Tutorial
    type: NPCHit
    ko: "\uADF8\uB7F0\uB370 \uAD50\uB3C4\uC18C \uADFC\uBB34\uB294 \uBAB8\uB9CC \uC798
      \uC4F0\uBA74 \uB41C\uB2E4\uACE0 \uD574\uACB0\uB418\uB294 \uAC8C \uC544\uB2C8\uC57C."
    en: 
  - key: DTxt_KR_T_23
    speaker: Frank
    mission: Tutorial
    type: NPCHit
    ko: "\uC544\uAE4C \uB0B4\uAC00 \uC6B4\uC774\uB791 \uBB50\uAC00 \uC911\uC694\uD558\uB2E4\uACE0
      \uD588\uC9C0?"
    en: 
  - key: DTxt_KR_T_24
    speaker: Frank
    mission: Tutorial
    type: NPCHit
    ko: "\uADF8\uB798, \uB208\uCE58\uB2E4."
    en: 
  - key: DTxt_KR_T_25
    speaker: Frank
    mission: Tutorial
    type: NPCHit
    ko: "\uC790, \uC131\uACBD \uCC45\uC744 \uD558\uB098 \uC904 \uD14C\uB2C8\uAE4C
      \uC798 \uC0B4\uD3B4\uBD10"
    en: 
  - key: DTxt_KR_T_26
    speaker: Frank
    mission: Tutorial
    type: NPCHit
    ko: "\uB9C8\uC6B0\uC2A4 \uC624\uB978\uCABD \uBC84\uD2BC\uC744 \uC774\uC6A9\uD558\uBA74
      \uB3CC\uB824\uBCFC \uC218 \uC788\uACE0, \uC67C\uCABD \uBC84\uD2BC\uC744 \uD074\uB9AD\uD558\uBA74
      \uCC45\uC744 \uC5F4\uC5B4\uBCFC \uC218 \uC788\uB2E4."
    en: 
  - key: DTxt_KR_T_27
    speaker: Frank
    mission: Tutorial
    type: BookRead
    ko: "\uC1A1\uACF3\uC774 \uB4E4\uC5B4 \uC788\uC9C0?"
    en: 
  - key: DTxt_KR_T_28
    speaker: Frank
    mission: Tutorial
    type: BookRead
    ko: "\uC774\uB7F0 \uC2DD\uC73C\uB85C \uC8C4\uC218 \uB188\uB4E4\uC740 \uBA40\uCA61\uD55C
      \uBB3C\uAC74\uC5D0 \uC704\uD5D8\uD55C \uAC83\uB4E4\uC744 \uC228\uACA8 \uB193\uB294\uB2E4."
    en: 
  - key: DTxt_KR_T_29
    speaker: Frank
    mission: Tutorial
    type: BookRead
    ko: "\uADF8\uB0E5 \uAC89\uBCF4\uAE30\uC5D0 \uC774\uC0C1 \uC5C6\uB2E4\uACE0 \uAD1C\uCC2E\uAD6C\uB098-
      \uD588\uB2E4\uAC00\uB294 \uBC14\uB85C (\uBAA9 \uAE0B\uB294 \uC2DC\uB289) \uC798\uB9AC\uB294
      \uAC70\uC9C0."
    en: 
  - key: DTxt_KR_T_30
    speaker: Frank
    mission: Tutorial
    type: BookRead
    ko: "\uADF8\uB798\uC11C \uB208\uCE58\uB97C \uC798 \uCC44\uC57C \uD574. \uBB50\uAC00
      \uC774\uC0C1\uD55C\uC9C0, \uBB50\uAC00 \uBA40\uCA61\uD55C \uAC74\uC9C0 \uC798
      \uD30C\uC545\uD558\uB294 \uAC8C \uC911\uC694\uD558\uAC70\uB4E0."
    en: 
  - key: DTxt_KR_T_31
    speaker: Frank
    mission: Tutorial
    type: BookClose
    ko: "\uC790\uC2E0\uC774 \uC5C6\uB2E4\uBA74 \uADF8\uB0E5 \uAC10\uBC29 \uC548\uC744
      \uC0C5\uC0C5\uC774 \uB4A4\uC9C0\uB77C\uACE0."
    en: 
  - key: DTxt_KR_T_32
    speaker: Frank
    mission: Tutorial
    type: BookClose
    ko: "\uAC10\uBC29 \uAD6C\uC11D\uAD6C\uC11D, \uBCBD\uB3CC \uD558\uB098\uD558\uB098\uAE4C\uC9C0
      \uB2E4."
    en: 
  - key: DTxt_KR_T_33
    speaker: Frank
    mission: Tutorial
    type: BookClose
    ko: "\uADF8\uB798. \uB0B4\uAC00 \uC598\uAE30\uD574\uC904 \uC218 \uC788\uB294
      \uAC74 \uB300\uCDA9 \uC774 \uC815\uB3C4\uB2E4."
    en: 
  - key: DTxt_KR_T_34
    speaker: Frank
    mission: Tutorial
    type: BookClose
    ko: "\uB2F9\uC7A5 \uC77C\uC190\uC774 \uBD80\uC871\uD558\uB2C8, \uB354 \uAC00\uB974\uCCD0\uC904
      \uC2DC\uAC04 \uB530\uC704\uB294 \uC5C6\uB2E8 \uB9D0\uC774\uC9C0."
    en: 
  - key: DTxt_KR_T_35
    speaker: Frank
    mission: Tutorial
    type: BookClose
    ko: "\uB098\uBA38\uC9C0\uB294 \uAD6C\uB974\uBA74\uC11C \uBC30\uC6CC\uB77C."
    en: 
  - key: DTxt_KR_T_36
    speaker: Frank
    mission: Tutorial
    type: BookClose
    ko: "\uC18C\uC7A5\uB2D8\uAED8 \uB9D0\uC744 \uAC78\uC5B4\uC11C \uB124\uAC00 \uC624\uB298
      \uD574\uC57C \uD558\uB294 \uBBF8\uC158\uC744 \uCCB4\uD06C\uD558\uACE0, \uC9C1\uC811
      \uC77C\uD574\uBCF4\uB77C\uACE0."
    en: 
  - key: DTxt_KR_T_37
    speaker: Frank
    mission: Tutorial
    type: BookClose
    ko: "\uC880 \uC624\uB798 \uBC84\uD168\uC11C \uB124 \uC4F8\uBAA8\uB97C \uC99D\uBA85\uD574\uBD10."
    en: 
  - key: DTxt_KR_M01_01
    speaker: Victor
    mission: Mission01
    type: Dialogue
    ko: "\uC790\uB124\uB3C4 \uB4E4\uB9AC\uB098?"
    en: 
  - key: DTxt_KR_M01_02
    speaker: Victor
    mission: Mission01
    type: Dialogue
    ko: "\uBA4D\uCCAD\uD55C \uC8C4\uC218\uB4E4\uC774 \uC5EC\uAE30\uAC00 \uAD50\uB3C4\uC18C\uC778
      \uAC83\uB3C4 \uC78A\uACE0 \uB610 \uC2DC\uB044\uB7FD\uAC8C \uAD6C\uB294\uAD6C\uB9CC."
    en: 
  - key: DTxt_KR_M01_03
    speaker: Victor
    mission: Mission01
    type: Dialogue
    ko: "\uC774\uB300\uB85C \uB194\uB450\uBA74 \uC2DC\uB044\uB7EC\uC6B4 \uD2C8\uC744
      \uD0C0\uC11C \uC218\uC0C1\uD55C \uC9D3\uC744 \uD558\uB294 \uB188\uC774 \uC0DD\uAE38
      \uAC8C \uBD84\uBA85\uD574!"
    en: 
  - key: DTxt_KR_M01_04
    speaker: Victor
    mission: Mission01
    type: Dialogue
    ko: "\uAC00\uC11C \uC2DC\uB044\uB7FD\uAC8C \uD558\uB294 \uB188\uB4E4\uC744 \uB2E4
      \uB450\uB4E4\uACA8 \uD328\uACE0 \uC624\uAC8C."
    en: 
  - key: DTxt_KR_M01_05
    speaker: Victor
    mission: Mission01
    type: Fin
    ko: "\uB2E4 \uC870\uC6A9\uD788 \uC2DC\uCF30\uB098?"
    en: 
  - key: DTxt_KR_M01_06
    speaker: Victor
    mission: Mission01
    type: Complete
    ko: "\uD558\uC5EC\uD2BC, \uD328\uC57C\uB9CC \uB9D0\uC744 \uB4E3\uB294\uB2E8 \uB9D0\uC774\uC9C0."
    en: 
  - key: DTxt_KR_M01_07
    speaker: Victor
    mission: Mission01
    type: Fail
    ko: "\uC8C4\uC218\uB4E4\uC744 \uC870\uC6A9\uD788 \uC2DC\uD0A4\uB294 \uAC83\uC870\uCC28
      \uBABB \uD558\uB294 \uAC74\uAC00? \uC790\uB124\uB294 \uD574\uACE0\uC77C\uC138!"
    en: 
  - key: DTxt_KR_M01_08
    speaker: Frank
    mission: Mission01
    type: Dialogue
    ko: "\uBD84\uBA85 \uC544\uAE4C \uC870\uC6A9\uD788 \uD558\uB77C\uACE0 \uC8FC\uC758\uB97C
      \uC8FC\uACE0 \uC654\uB294\uB370 \uC65C \uB610 \uC2DC\uB044\uB7EC\uC6B4 \uAC70\uC57C\u2026"
    en: 
  - key: DTxt_KR_M01_09
    speaker: Frank
    mission: Mission01
    type: Dialogue
    ko: "\uC9C4\uC9DC \uAE30\uC808\uD560 \uB54C\uAE4C\uC9C0 \uD328\uB4E0\uAC00 \uD574\uC57C\uC9C0"
    en: 
  - key: DTxt_KR_M02_01
    speaker: Victor
    mission: Mission02
    type: Dialogue
    ko: "\uC950\uC0C8\uB07C\uAC00 \uC815\uBCF4\uB97C \uAC00\uC838\uC654\uB2E4. \uC8C4\uC218
      \uB188\uB4E4\uC774 \uAC10\uBC29 \uC548\uC5D0 \uBB34\uAE30\uB97C \uC228\uACA8
      \uB1A8\uB2E4\uB294\uAD70."
    en: 
  - key: DTxt_KR_M02_02
    speaker: Victor
    mission: Mission02
    type: Dialogue
    ko: "\uBC16\uC5D0\uC11C\uB3C4 \uC0AC\uACE0 \uCCD0\uC11C \uB4E4\uC5B4\uC628 \uB188\uB4E4\uC774
      \uB610 \uBB34\uAE30\uB85C \uC0AC\uACE0\uB97C \uCE58\uB824\uACE0 \uD574?"
    en: 
  - key: DTxt_KR_M02_03
    speaker: Victor
    mission: Mission02
    type: Dialogue
    ko: "\uADF8\uB807\uAC8C\uB294 \uBABB \uB450\uC9C0. \uC554, \uADF8\uB807\uAC8C\uB294
      \uBABB \uB450\uACE0 \uB9D0\uACE0."
    en: 
  - key: DTxt_KR_M02_04
    speaker: Victor
    mission: Mission02
    type: Dialogue
    ko: "\uAC10\uBC29\uC744 \uC0C5\uC0C5\uC774 \uB4A4\uC838\uC11C \uC804\uBD80 \uC555\uC218\uD574
      \uC640."
    en: 
  - key: DTxt_KR_M02_05
    speaker: Victor
    mission: Mission02
    type: Fin
    ko: "\uBB34\uAE30\uB97C \uC804\uBD80 \uCC3E\uC558\uB098?"
    en: 
  - key: DTxt_KR_M02_06
    speaker: Victor
    mission: Mission02
    type: Complete
    ko: "\uC5B4\uD734, \uC801\uC5B4\uB3C4 \uC624\uB298\uC740 \uBB34\uAE30 \uB54C\uBB38\uC5D0
      \uC0AC\uACE0\uB0A0 \uC77C\uC740 \uC5C6\uACA0\uAD70."
    en: 
  - key: DTxt_KR_M02_07
    speaker: Victor
    mission: Mission02
    type: Fail
    ko: "\uC790\uB124\uAC00 \uB193\uCE5C \uBB34\uAE30 \uB54C\uBB38\uC5D0 \uC8C4\uC218
      \uD55C\uBA85\uC774 \uC2E4\uB824\uB098\uAC14\uC5B4! \uC790\uB124\uB294 \uD574\uACE0\uC57C!"
    en: 
  - key: DTxt_KR_M02_08
    speaker: Frank
    mission: Mission02
    type: Dialogue
    ko: "\uB188\uB4E4\uC774 \uC228\uACA8\uB193\uC740 \uBB34\uAE30\uB97C \uCC3E\uC73C\uB824\uBA74
      \uAC10\uBC29 \uC548\uC744 \uAD6C\uC11D\uAD6C\uC11D \uAF3C\uAF3C\uD788 \uBD10\uC57C\uD574"
    en: 
  - key: DTxt_KR_M02_09
    speaker: Frank
    mission: Mission02
    type: Dialogue
    ko: "\uB124\uAC00 \uBC29 \uC548\uC744 \uC0B4\uD53C\uB294 \uD2C8\uC744 \uD0C0\uC11C
      \uB364\uBCBC\uB4DC\uB294 \uB188\uB4E4\uC774 \uC788\uC744 \uC218 \uC788\uC73C\uB2C8\uAE4C
      \uC8FC\uC758\uD558\uB77C\uACE0"
    en: 
  - key: DTxt_KR_M03_01
    speaker: Victor
    mission: Mission03
    type: Dialogue
    ko: "\uC774 \uBE4C\uC5B4\uBA39\uC744 7\uAD6C\uC5ED\uC5D0\uB294 \uB300\uCCB4 \uBB34\uC2A8
      \uBB38\uC81C\uAC00 \uC788\uB294 \uAC78\uAE4C?"
    en: 
  - key: DTxt_KR_M03_02
    speaker: Victor
    mission: Mission03
    type: Dialogue
    ko: "\uAD50\uB3C4\uC18C\uC5D0 \uB4E4\uC5B4\uC624\uC790\uB9C8\uC790 \uD5C8\uD2BC
      \uC9D3\uAC70\uB9AC\uB97C \uD558\uB294 \uB188\uB4E4\uC774 \uB9CE\uB2E8 \uB9D0\uC774\uC9C0."
    en: 
  - key: DTxt_KR_M03_03
    speaker: Victor
    mission: Mission03
    type: Dialogue
    ko: "\uC624\uB298 \uC0C8\uB85C \uB4E4\uC5B4\uC628 \uB188\uB4E4 \uC911\uC5D0\uB3C4
      \uC774\uC0C1\uD55C \uC9D3\uAC70\uB9AC\uB97C \uD558\uB294 \uB188\uB4E4\uC774
      \uC788\uC744 \uAC8C \uBD84\uBA85\uD574."
    en: 
  - key: DTxt_KR_M03_04
    speaker: Victor
    mission: Mission03
    type: Dialogue
    ko: "\uAD50\uB3C4\uC18C\uB97C \uC21C\uCC30\uD558\uBA74\uC11C, \uC774\uC0C1\uD55C
      \uC9D3\uAC70\uB9AC\uB97C \uD558\uB294 \uB188\uB4E4\uC774 \uC788\uC73C\uBA74
      \uC804\uBD80 \uB450\uB4E4\uACA8 \uD328\uACE0 \uC640."
    en: 
  - key: DTxt_KR_M03_05
    speaker: Victor
    mission: Mission03
    type: Fin
    ko: "\uC774\uC0C1\uD55C \uC8C4\uC218\uB4E4\uC740 \uC804\uBD80 \uB450\uB4E4\uACA8
      \uD328\uACE0 \uC654\uB098?"
    en: 
  - key: DTxt_KR_M03_06
    speaker: Victor
    mission: Mission03
    type: Complete
    ko: "\uC0DD\uAC01\uBCF4\uB2E4 \uC2F8\uC6C0 \uC880 \uD558\uB294\uAD70, \uADF8\uB798?"
    en: 
  - key: DTxt_KR_M03_07
    speaker: Victor
    mission: Mission03
    type: Fail
    ko: "\uB9DB\uC774 \uAC04 \uB188\uB4E4\uB9CC \uB450\uB4E4\uACA8 \uD328\uACE0 \uC624\uB77C\uB294
      \uAC8C \uADF8\uB807\uAC8C \uC5B4\uB824\uC6E0\uB098? \uC790\uB124\uB294 \uD574\uACE0\uC77C\uC138!"
    en: 
  - key: DTxt_KR_M03_08
    speaker: Mimi
    mission: Mission03
    type: Dialogue
    ko: "\uC5B4\uBA38, \uC2E0\uCC38\uC774\uC57C? \uADC0\uC5FD\uAC8C \uC0DD\uACBC\uB124"
    en: 
  - key: DTxt_KR_M03_09
    speaker: Mimi
    mission: Mission03
    type: Dialogue
    ko: "\uB098\uB97C \uC704\uD574 \uBE44\uB204 \uC880 \uC8FC\uC6CC\uC8FC\uC9C0 \uC54A\uC744\uB798?
      \uC790\uAE30\uC57C?"
    en: 
  - key: DTxt_KR_M03_10
    speaker: Mimi
    mission: Mission03
    type: Dialogue
    ko: "\uBE44\uB204\uB97C \uC90D\uC9C0 \uC54A\uB294\uB2E4\uBA74, \uC0C1\uB300\uD574\uC8FC\uC9C0
      \uC54A\uC744 \uAC70\uC57C. \uD6C4\uD6C4\uD6C4\xB7\xB7\xB7."
    en: 
  - key: DTxt_KR_M03_11
    speaker: Frank
    mission: Mission03
    type: Dialogue
    ko: "\uBA40\uCA61\uD55C \uCC99\uC744 \uD558\uB2E4\uAC00\uB3C4, \uC815\uC791 \uAC10\uBC29
      \uC548\uC5D0 \uB4E4\uC5B4\uAC00\uBA74 \uC18D\uB0B4\uB97C \uB4DC\uB7EC\uB0B4\uB294
      \uB188\uB4E4\uC774 \uC788\uC9C0"
    en: 
  - key: DTxt_KR_M03_12
    speaker: Frank
    mission: Mission03
    type: Dialogue
    ko: "\uB300\uB193\uACE0 \uBB38\uC81C\uAC00 \uC788\uB294 \uD2F0\uB97C \uB0B4\uC8FC\uBA74
      \uC77C\uD558\uAE30 \uC880 \uD3B8\uD560 \uD150\uB370 \uB9D0\uC774\uC57C"
    en: 
  - key: DTxt_KR_M04_01
    speaker: Victor
    mission: Mission04
    type: Dialogue
    ko: "\uBC8C\uC368 \uC790\uB124\uAC00 \uCD9C\uADFC\uD560 \uC2DC\uAC04\uC778\uAC00?
      \uC544\uC9C1 \uD504\uB7AD\uD06C\uAC00 \uC548 \uC654\uB294\uB370?"
    en: 
  - key: DTxt_KR_M04_02
    speaker: Victor
    mission: Mission04
    type: Dialogue
    ko: "\uC774\uAC70 \uC774\uC0C1\uD558\uAD70. \uC790\uB124, \uD504\uB7AD\uD06C\uAC00
      \uC5B4\uB514 \uAC14\uB294\uC9C0 \uC544\uB098?"
    en: 
  - key: DTxt_KR_M04_03
    speaker: Victor
    mission: Mission04
    type: Dialogue
    ko: "\uBD84\uBA85 \uC544\uAE4C \uC21C\uCC30\uD558\uB7EC \uAC14\uB294\uB370, \uC544\uC9C1\uB3C4
      \uB3CC\uC544\uC624\uC9C0 \uC54A\uC558\uB2E4\uB2C8."
    en: 
  - key: DTxt_KR_M04_04
    speaker: Victor
    mission: Mission04
    type: Dialogue
    ko: "\uAD50\uB3C4\uC18C\uB85C \uB0B4\uB824\uAC00\uC11C \uD504\uB7AD\uD06C\uB97C
      \uCC3E\uC544\uBCF4\uAC8C."
    en: 
  - key: DTxt_KR_M04_05
    speaker: Victor
    mission: Mission04
    type: Fin
    ko: "\uD504\uB7AD\uD06C\uB97C \uCC3E\uC558\uB098?"
    en: 
  - key: DTxt_KR_M04_06
    speaker: Victor
    mission: Mission04
    type: Complete
    ko: "\uBB50? \uC8C4\uC218\uB4E4\uC774 \uD504\uB7AD\uD06C\uB85C \uBCC0\uC7A5\uD558\uACE0
      \uC788\uC5C8\uB2E4\uACE0? \uC774\uC81C\uB294 \uBCC4 \uC9D3\uC744 \uB2E4 \uD558\uB294\uAD70."
    en: 
  - key: DTxt_KR_M04_07
    speaker: Victor
    mission: Mission04
    type: Fail
    ko: "\uBB50? \uC8C4\uC218\uB791 \uD504\uB7AD\uD06C\uB97C \uD5F7\uAC08\uB838\uB2E4\uACE0?
      \uC790\uB124 \uB208\uC740 \uC7A5\uC2DD\uC778\uAC00? \uC790\uB124\uB294 \uD574\uACE0\uC57C!"
    en: 
  - key: DTxt_KR_M04_08
    speaker: Frank
    mission: Mission04
    type: Complete
    ko: "\uD734. \uC870\uAE08\uB9CC \uB2A6\uC5C8\uC5B4\uB3C4 \uB0B4 \uBA38\uB9AC\uD1B5\uC774
      \uB0A0\uC544\uAC08 \uBED4\uD588\uB2E4. \uB2E4\uD589\uD788 \uB208\uCE58\uB294
      \uCC59\uACBC\uB098 \uBD10, \uC2E0\uCC38?"
    en: 
  - key: DTxt_KR_M04_09
    speaker: Frank
    mission: Mission04
    type: Fail
    ko: "\uB108 \uC9C0\uAE08 \uB204\uAD74 \uB54C\uB9AC\uB294 \uAC70\uC57C \uBA4D\uCCAD\uC544!"
    en: 
  - key: DTxt_KR_M04_10
    speaker: Frank
    mission: Mission04
    type: FrankArgue
    ko: "\uBE4C\uC5B4\uBA39\uC744 \uC8C4\uC218 \uB188\uB4E4. \uC774\uC81C\uB294 \uD558\uB2E4,
      \uD558\uB2E4 \uB098\uB85C \uBCC0\uC7A5\uC744 \uD574?"
    en: 
  - key: DTxt_KR_M04_11
    speaker: Frank
    mission: Mission04
    type: FrankArgue
    ko: "\uBB50\uB77C\uB294 \uAC70\uB0D0, \uAC00\uC9DC! \uC740\uADFC\uC2AC\uCA4D
      \uB098\uC778 \uCC99\uC744 \uD558\uACE0 \uC788\uAD70!"
    en: 
  - key: DTxt_KR_M04_12
    speaker: Frank
    mission: Mission04
    type: FrankArgue
    ko: "\uB9C8\uCE68 \uC798 \uC654\uB2E4 \uC2E0\uCC38. \uB124\uAC00 \uBCF4\uAE30\uC5D4
      \uB204\uAC00 \uC9C4\uC9DC \uAC19\uB098?"
    en: 
  - key: DTxt_KR_M04_13
    speaker: Frank
    mission: Mission04
    type: FrankArgue
    ko: "\uC560\uC1A1\uC544, \uC18D\uC9C0 \uB9C8\uB77C. \uB204\uAC00 \uC9C4\uC9DC\uC778\uC9C0,
      \uC798 \uC0B4\uD3B4\uBCF4\uACE0 \uD310\uB2E8\uD574."
    en: 
  - key: DTxt_KR_M04_14
    speaker: Frank
    mission: Mission04
    type: FrankArgue
    ko: "\uADF8\uB798! \uB2E4\uB978 \uB188\uB4E4\uC774 \uBABB \uC6C0\uC9C1\uC774\uAC8C
      \uACAC\uC81C\uD558\uACE0 \uC788\uC744 \uD14C\uB2C8 \uB124\uAC00 \uAC00\uC9DC\uB4E4\uC744
      \uC9C4\uC555\uD574!"
    en: 
  - key: DTxt_KR_M05_01
    speaker: Victor
    mission: Mission05
    type: Dialogue
    ko: "\uADF8\uB7EC\uACE0 \uBCF4\uB2C8, \uC2AC\uC2AC \uC18C\uC9C0\uD488 \uAC80\uC0AC\uB97C
      \uD560 \uB54C\uAC00 \uB410\uC9C0?"
    en: 
  - key: DTxt_KR_M05_02
    speaker: Victor
    mission: Mission05
    type: Dialogue
    ko: "\uC8FC\uAE30\uC801\uC73C\uB85C \uC548 \uD574\uC8FC\uBA74 \uAD50\uB3C4\uC18C
      \uC548\uC5D0 \uC4F8\uB370\uC5C6\uB294 \uAC83\uB4E4\uC774 \uB3CC\uC544\uB2E4\uB2CC\uB2E8
      \uB9D0\uC774\uC9C0."
    en: 
  - key: DTxt_KR_M05_03
    speaker: Victor
    mission: Mission05
    type: Dialogue
    ko: "\uC774\uAC83\uB4E4\uC774 \uB098\uB97C \uC544\uC8FC \uC6B0\uC2B5\uAC8C \uC544\uB294
      \uBAA8\uC591\uC774\uC57C."
    en: 
  - key: DTxt_KR_M05_04
    speaker: Victor
    mission: Mission05
    type: Dialogue
    ko: "\uAD50\uB3C4\uC18C\uC5D0 \uC788\uC5B4\uC11C\uB294 \uC548 \uB420 \uBB3C\uD488\uB4E4\uC744
      \uC804\uBD80 \uC555\uC218\uD558\uACE0 \uC640!"
    en: 
  - key: DTxt_KR_M05_05
    speaker: Victor
    mission: Mission05
    type: Fin
    ko: "\uC8C4\uC218\uB4E4\uC774 \uC228\uACA8\uB454 \uAE08\uC9C0 \uBB3C\uD488\uB4E4\uC740
      \uCC3E\uC558\uB098?"
    en: 
  - key: DTxt_KR_M05_06
    speaker: Victor
    mission: Mission05
    type: Complete
    ko: "\uC815\uB9D0\uC774\uC9C0, \uC5B4\uB514\uC11C \uACC4\uC18D \uB4E4\uC5EC\uC624\uB294
      \uAC74\uC9C0 \uBAA8\uB974\uACA0\uC5B4."
    en: 
  - key: DTxt_KR_M05_07
    speaker: Victor
    mission: Mission05
    type: Fail
    ko: "\uC774\uB807\uAC8C \uC77C\uC744 \uB300\uCDA9 \uD558\uBA74 \uC8C4\uC218\uB4E4\uC774
      \uB098\uB97C \uB9CC\uB9CC\uD558\uAC8C \uBCF4\uC9C0 \uC54A\uACA0\uB098! \uC774
      \uB530\uC704\uB85C \uD560 \uAC70\uBA74 \uB54C\uB824 \uCE58\uC6CC!"
    en: 
  - key: DTxt_KR_M05_08
    speaker: Frank
    mission: Mission05
    type: Dialogue
    ko: "\uAC10\uBC29\uC744 \uB4A4\uC9C8 \uB54C\uB294 \uBCBD\uC774\uB098 \uBC14\uB2E5\uB3C4
      \uD56D\uC0C1 \uAF3C\uAF3C\uD558\uAC8C \uC0B4\uD3B4\uBCF4\uB294 \uAC8C \uC88B\uC744
      \uAC70\uC57C."
    en: 
  - key: DTxt_KR_M05_09
    speaker: Frank
    mission: Mission05
    type: Dialogue
    ko: "\uB140\uC11D\uB4E4\uC740 \uC815\uB9D0 \uC628\uAC16 \uACF3\uC5D0 \uBB3C\uAC74\uC744
      \uC228\uACA8 \uB193\uB294\uB2E8 \uB9D0\uC774\uC9C0."
    en: 
  - key: DTxt_KR_M06_01
    speaker: Victor
    mission: Mission06
    type: Dialogue
    ko: "\uC81C\uC815\uC2E0\uC774 \uC544\uB2C8\uAD70, \uC81C\uC815\uC2E0\uC774 \uC544\uB2C8\uC57C."
    en: 
  - key: DTxt_KR_M06_02
    speaker: Victor
    mission: Mission06
    type: Dialogue
    ko: "\uC81C 7\uAD6C\uC5ED\uC5D0 \uC218\uAC10 \uC911\uC778 \uAC31\uB2E8\uC6D0
      \uC911 \uD55C \uBA85\uC774 \uAD50\uB3C4\uC18C\uC5D0 \uCD1D\uAE30\uB97C \uBC00\uBC18\uC785\uD558\uB824\uB2E4
      \uAC78\uB9B0 \uD6C4, \uB3C4\uB9DD\uCCE4\uB2E4."
    en: 
  - key: DTxt_KR_M06_03
    speaker: Victor
    mission: Mission06
    type: Dialogue
    ko: "\uC6A9\uC758\uC790 \uC14B \uC911 \uD558\uB098\uAC00 \uBC94\uC778\uC778 \uAC74
      \uD655\uC2E4\uD55C\uB370, \uC5BC\uAD74\uC744 \uAC00\uB9AC\uACE0 \uC788\uB358
      \uD0D3\uC5D0 \uB204\uAD6C\uC778\uC9C0\uB294 \uBAA8\uB974\uACA0\uB2E8 \uB9D0\uC774\uC9C0"
    en: 
  - key: DTxt_KR_M06_04
    speaker: Victor
    mission: Mission06
    type: Dialogue
    ko: "\uC6A9\uC758\uC790\uB4E4\uACFC \uB300\uD654\uD574 \uC9C4\uC9DC \uBC94\uC778\uC744
      \uCC3E\uC544\uB0B4\uAC8C. \uC14B \uC911 \uAC70\uC9D3\uB9D0 \uD558\uB294 \uB188\uC774
      \uBC94\uC778\uC774\uACA0\uC9C0."
    en: 
  - key: DTxt_KR_M06_05
    speaker: Victor
    mission: Mission06
    type: Fin
    ko: "\uBC94\uC778\uC740 \uCC3E\uC558\uB098?"
    en: 
  - key: DTxt_KR_M06_06
    speaker: Victor
    mission: Mission06
    type: Complete
    ko: "\uAC10\uD788 \uC2E0\uC131\uD55C \uAD50\uB3C4\uC18C \uC548\uC5D0 \uCD1D\uAE30\uB97C
      \uB4E4\uC774\uB2E4\uB2C8, \uB0B4\uAC00 \uC9C1\uC811 \uAD50\uC721\uD558\uB3C4\uB85D
      \uD558\uACA0\uC5B4."
    en: 
  - key: DTxt_KR_M06_07
    speaker: Victor
    mission: Mission06
    type: Fail
    ko: "\uC9C4\uBC94\uC744 \uB193\uCCE4\uC5B4! \uB610 \uCD1D\uAE30\uAC00 \uBC1C\uACAC\uB410\uB2E4\uACE0!
      \uC774\uB807\uAC8C \uD5DB\uB2E4\uB9AC\uB97C \uC9DA\uB2E4\uB2C8. \uC790\uB124\uB294
      \uD574\uACE0\uC57C!"
    en: 
  - key: DTxt_KR_M06_08
    speaker: Frank
    mission: Mission06
    type: Fin
    ko: "\uADF8\uB798, \uBC94\uC778\uC774 \uB204\uAD6C\uC778\uC9C0 \uC54C\uACA0\uB098?"
    en: 
  - key: DTxt_KR_M06_09
    speaker: Player
    mission: Mission06
    type: Choice
    ko: "\uBC94\uC778\uC740 \uC548\uD1A0\uB2C8\uB2E4."
    en: 
  - key: DTxt_KR_M06_10
    speaker: Player
    mission: Mission06
    type: Choice
    ko: "\uBC94\uC778\uC740 \uB9AC\uCC28\uB4DC\uB2E4"
    en: 
  - key: DTxt_KR_M06_11
    speaker: Player
    mission: Mission06
    type: Choice
    ko: "\uBC94\uC778\uC740 \uB808\uC624\uB2E4"
    en: 
  - key: DTxt_KR_M06_12
    speaker: Suspect1
    mission: Mission06
    type: Dialogue
    ko: "Suspect2\uB294 \uC9C0\uAE08 \uAC70\uC9D3\uB9D0\uC744 \uD558\uACE0 \uC788\uC5B4.
      \uC800 \uB140\uC11D\uC774 \uBC94\uC778\uC774\uC57C"
    en: 
  - key: DTxt_KR_M06_13
    speaker: Suspect1
    mission: Mission06
    type: Dialogue
    ko: "\uB188\uC758 \uBC14\uC9C0\uC5D0 \uBB3B\uC740 \uC5BC\uB8E9\uC744 \uBD10.
      \uCD1D\uAE30 \uC190\uC9C8\uD560 \uB54C \uC4F0\uB294 \uC724\uD65C\uC720\uB791
      \uB611\uAC19\uC740 \uC0C9\uAE54\uC774\uC9C0"
    en: 
  - key: DTxt_KR_M06_14
    speaker: Suspect1
    mission: Mission06
    type: Dialogue
    ko: "\uB09C \uC5B4\uC81C \uD558\uB8E8 \uC885\uC77C \uC758\uBB34\uC2E4\uC5D0 \uC788\uC5C8\uC5B4."
    en: 
  - key: DTxt_KR_M06_15
    speaker: Suspect2
    mission: Mission06
    type: Dialogue
    ko: "Suspect3\uB294 \uC194\uC9C1\uD55C \uB188\uC774\uC57C."
    en: 
  - key: DTxt_KR_M06_16
    speaker: Suspect2
    mission: Mission06
    type: Dialogue
    ko: "\uBC94\uC778\uC740 Suspect1\uC774\uC57C. \uB098\uB098 Suspect3\uB294 \uC2DC\uB825\uC774
      \uC548 \uC88B\uC544\uC11C \uCD1D\uC744 \uC4F0\uC9C0 \uC54A\uB294\uB2E4\uACE0."
    en: 
  - key: DTxt_KR_M06_17
    speaker: Suspect2
    mission: Mission06
    type: Dialogue
    ko: "\uB09C \uC5B4\uC81C \uC6B4\uB3D9\uC7A5\uC5D0\uC11C \uB370\uB4DC\uB9AC\uD504\uD2B8\uB97C
      \uD588\uC5B4. \uB0B4 \uBC14\uC9C0\uC5D0 \uBB3B\uC740 \uAC74 \uC6B4\uB3D9\uD558\uB2E4
      \uBB3B\uC740 \uAC80\uC740 \uAD6C\uB9AC\uC2A4\uC77C \uBFD0\uC774\uC57C."
    en: 
  - key: DTxt_KR_M06_18
    speaker: Suspect3
    mission: Mission06
    type: Dialogue
    ko: "Suspect1\uB294 \uAC70\uC9D3\uB9D0\uC7C1\uC774\uC57C. Suspect1\uC758 \uB9D0\uC744
      \uBBFF\uC5B4\uC11C\uB294 \uC548 \uB3FC."
    en: 
  - key: DTxt_KR_M06_19
    speaker: Suspect3
    mission: Mission06
    type: Dialogue
    ko: "Suspect2\uB294 \uBC94\uC778\uC774 \uC544\uB2C8\uC57C. \uCD1D\uAE30\uB97C
      \uC190\uC9C8\uD560 \uB54C \uC4F0\uB294 \uC724\uD65C\uC720\uB294 \uD30C\uB780\uC0C9\uC774\uB77C\uACE0."
    en: 
  - key: DTxt_KR_M06_20
    speaker: Suspect3
    mission: Mission06
    type: Dialogue
    ko: "\uB09C \uC5B4\uC81C \uC138\uD0C1\uC2E4\uC5D0 \uC788\uC5C8\uC5B4. \uC637\uC740
      \uC5B4\uC81C \uC785\uC740 \uADF8\uB300\uB85C\uACE0."
    en: 
  - key: DTxt_KR_M06_21
    speaker: Frank
    mission: Mission06
    type: AfterChoice
    ko: "\uC88B\uC544. \uB0B4\uAC00 \uB140\uC11D\uC744 \uB354 \uC790\uC138\uD788
      \uC2EC\uBB38\uD558\uB3C4\uB85D \uD558\uC9C0. \uAD50\uB3C4\uC18C\uC7A5\uB2D8\uAED8
      \uAC00\uC11C \uBCF4\uACE0\uD574"
    en: 
  - key: DTxt_KR_M07_01
    speaker: Victor
    mission: Mission07
    type: Dialogue
    ko: "\uC950\uC0C8\uB07C\uAC00 \uC544\uC8FC \uC911\uC694\uD55C \uCCA9\uBCF4\uB97C
      \uB4E4\uACE0 \uC654\uB2E4."
    en: 
  - key: DTxt_KR_M07_02
    speaker: Victor
    mission: Mission07
    type: Dialogue
    ko: "\uC5EC\uAE30, 7\uAD6C\uC5ED \uC548 \uC8C4\uC218\uB4E4\uC774 \uD3ED\uB3D9\uC744
      \uC900\uBE44\uD558\uACE0 \uC788\uB2E4\uB294\uAD70."
    en: 
  - key: DTxt_KR_M07_03
    speaker: Victor
    mission: Mission07
    type: Dialogue
    ko: "\uD3ED\uB3D9 \uC608\uC815\uC77C\uC740 \uC624\uB298 \uC0C8\uBCBD. \uB531
      \uC790\uB124 \uADFC\uBB34 \uC2DC\uAC04\uC774\uC9C0."
    en: 
  - key: DTxt_KR_M07_04
    speaker: Victor
    mission: Mission07
    type: Dialogue
    ko: "\uB140\uC11D\uB4E4\uC774 \uD3ED\uB3D9\uC744 \uC77C\uC73C\uD0A4\uC9C0 \uBABB\uD558\uB3C4\uB85D
      \uC804\uBD80 \uB2E4 \uB450\uB4E4\uACA8 \uD328\uC11C \uBB34\uB825\uD654 \uC2DC\uCF1C!"
    en: 
  - key: DTxt_KR_M07_05
    speaker: Victor
    mission: Mission07
    type: Fin
    ko: "\uC8C4\uC218\uB4E4\uC740 \uC804\uBD80 \uC9C4\uC555\uD588\uB098?"
    en: 
  - key: DTxt_KR_M07_06
    speaker: Victor
    mission: Mission07
    type: Complete
    ko: "\xB7\xB7\xB7\uACE0\uC0DD \uB9CE\uC558\uB124."
    en: 
  - key: DTxt_KR_M07_07
    speaker: Victor
    mission: Mission07
    type: Complete
    ko: "\uBB34\uC0AC\uACE0 7\uC77C\uCC28\uB97C \uB2EC\uC131\uD558\uB2E4\uB2C8. \uBBFF\uAE30\uC9C0
      \uC54A\uB294\uAD6C\uB9CC."
    en: 
  - key: DTxt_KR_M07_08
    speaker: Victor
    mission: Mission07
    type: Complete
    ko: "\uC790\uB124\uB294 \uC815\uB9D0 \uB300\uB2E8\uD55C \uC77C\uC744 \uD574\uB0C8\uC5B4."
    en: 
  - key: DTxt_KR_M07_09
    speaker: Victor
    mission: Mission07
    type: Complete
    ko: "\uB2E4\uB978 \uACF3\uC5D0\uC11C\uB77C\uBA74 \uBAA8\uB974\uACA0\uC9C0\uB9CC
      \uC5EC\uAE30, \uC81C 7\uAD6C\uC5ED\uC5D0\uC11C\uB294 \uBB34\uC0AC\uACE0 7\uC77C\uCC28\uB97C
      \uB2EC\uC131\uD55C \uC801\uC774 \uD55C \uBC88\uB3C4 \uC5C6\uB2E4\uACE0!"
    en: 
  - key: DTxt_KR_M07_10
    speaker: Victor
    mission: Mission07
    type: Complete
    ko: "\uC790\uB124\uAC00 \uBB34\uC0AC\uACE0 \uB0A0\uC9DC\uB97C \uAC31\uC2E0\uD560
      \uB54C\uB9C8\uB2E4 \uC870\uB9C8\uC870\uB9C8\uD558\uBA74\uC11C\uB3C4 \uAE30\uB300\uD588\uB294\uB370"
    en: 
  - key: DTxt_KR_M07_11
    speaker: Victor
    mission: Mission07
    type: Complete
    ko: "\uC9C4\uC9DC\uB85C \uC774\uB807\uAC8C \uBB34\uC0AC\uACE0 7\uC77C\uCC28\uB97C
      \uB2EC\uC131\uD558\uB2E4\uB2C8."
    en: 
  - key: DTxt_KR_M07_12
    speaker: Victor
    mission: Mission07
    type: Complete
    ko: "\uB0B4\uAC00 \uADFC\uBB34\uD558\uB294 \uB3D9\uC548 \uD55C \uBC88\uC774\uB77C\uB3C4
      \uC131\uACF5\uD560 \uC218 \uC788\uC744 \uAC70\uB77C\uACE0 \uAE30\uB300 \uC548
      \uD588\uB294\uB370, \uC815\uB9D0 \uACE0\uB9D9\uB124."
    en: 
  - key: DTxt_KR_M07_13
    speaker: Victor
    mission: Mission07
    type: Complete
    ko: "\uB2E4\uC2DC \uD55C \uBC88 \uACE0\uC0DD \uB9CE\uC558\uB124."
    en: 
  - key: DTxt_KR_M07_14
    speaker: Victor
    mission: Mission07
    type: Complete
    ko: "\uC55E\uC73C\uB85C\uB3C4 \uC774\uB807\uAC8C, \uBB34\uC0AC\uACE0 \uB0A0\uC9DC\uB97C
      \uAC31\uC2E0\uD574\uBCF4\uC790\uACE0!"
    en: 
  - key: DTxt_KR_M07_15
    speaker: Victor
    mission: Mission07
    type: Fail
    ko: "\uC774\uBC88\uC5D0\uC57C \uB9D0\uB85C \uBB34\uC0AC\uACE0 7\uC77C\uC744 \uCC0D\uC5B4\uBCF4\uB098
      \uD588\uB294\uB370, \uACB0\uAD6D \uC2E4\uD328\uAD6C\uB9CC. \uC5B4\uCA54 \uC218
      \uC5C6\uC9C0."
    en: 
  - key: DTxt_KR_M07_16
    speaker: Frank
    mission: Mission07
    type: Dialogue
    ko: "\uC8C4\uC218 \uC0C8\uB07C\uB4E4\uACFC\uC758 \uC804\uD22C\uB294 \uB298 \uC870\uC2EC\uD574\uC57C
      \uD574."
    en: 
  - key: DTxt_KR_M07_17
    speaker: Frank
    mission: Mission07
    type: Dialogue
    ko: "\uB140\uC11D\uB4E4\uC758 \uACF5\uACA9\uC740 \uD53C\uD558\uACE0, \uB124 \uACF5\uACA9\uC740
      \uB9DE\uCDB0\uC57C \uD558\uC9C0. \uBB50, \uADF8\uAC8C \uC5B4\uB824\uC6B4 \uAC70\uC9C0\uB9CC."
    en: 
